<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Product>XIVLauncher Vcdiff Shim</Product>
        <AssemblyTitle>XIVLauncher Vcdiff Shim</AssemblyTitle>
        <Description>32-bit vcdiff merge worker for V3 game patching.</Description>
        <VersionPrefix>1.0.0</VersionPrefix>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
    </PropertyGroup>
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0-windows</TargetFramework>
        <RuntimeIdentifier>win-x64</RuntimeIdentifier>
        <PlatformTarget>x64</PlatformTarget>
        <LangVersion>latest</LangVersion>
        <Deterministic>true</Deterministic>
        <OutputPath>..\bin\VcdiffShim\</OutputPath>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
        <SelfContained>false</SelfContained>
    </PropertyGroup>
    <PropertyGroup>
        <XdeltaShimDir>$(MSBuildProjectDirectory)\..\XIVLauncher.XdeltaShim</XdeltaShimDir>
        <XdeltaShimDllOutput>$(XdeltaShimDir)\target\release\xivlauncher_xdelta_shim.dll</XdeltaShimDllOutput>
        <SkipXdeltaShim Condition="'$(SkipXdeltaShim)' == ''">false</SkipXdeltaShim>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Serilog"/>
        <PackageReference Include="Serilog.Sinks.Async"/>
        <PackageReference Include="Serilog.Sinks.Console"/>
        <PackageReference Include="Serilog.Sinks.File"/>
        <PackageReference Include="SharedMemory"/>
    </ItemGroup>
    <Target Name="BuildXdeltaShim"
            BeforeTargets="BeforeBuild"
            Condition="'$(SkipXdeltaShim)' != 'true'">
        <Error Condition="!Exists('$(XdeltaShimDir)\Cargo.toml')"
               Text="XIVLauncher.XdeltaShim sources are missing."/>

        <Exec Command="cargo --version" ConsoleToMsBuild="true" IgnoreExitCode="true">
            <Output TaskParameter="ExitCode" PropertyName="_CargoExitCode"/>
        </Exec>
        <Error Condition="'$(_CargoExitCode)' != '0'"
               Text="'cargo' not found on PATH. Install the Rust toolchain from https://rustup.rs, or pass /p:SkipXdeltaShim=true."/>

        <Exec Command="cargo build --release"
              WorkingDirectory="$(XdeltaShimDir)"
              ConsoleToMsBuild="true"/>

        <Error Condition="!Exists('$(XdeltaShimDllOutput)')"
               Text="XIVLauncher.XdeltaShim build succeeded but '$(XdeltaShimDllOutput)' is missing."/>

        <Copy SourceFiles="$(XdeltaShimDllOutput)"
              DestinationFiles="$(OutDir)xivlauncher_xdelta_shim.dll"
              SkipUnchangedFiles="true"/>
    </Target>
</Project>
