<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <FontFamily x:Key="AppFontFamily">pack://application:,,,/XIVLauncherCN;component/Resources/Fonts/#HarmonyOS Sans SC</FontFamily>

    <Style TargetType="{x:Type Window}">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Language" Value="zh-CN" />
    </Style>

    <Style TargetType="{x:Type UserControl}">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Language" Value="zh-CN" />
    </Style>

    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Language" Value="zh-CN" />
    </Style>

    <Style TargetType="{x:Type Menu}">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Language" Value="zh-CN" />
    </Style>

    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Language" Value="zh-CN" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Language" Value="zh-CN" />
    </Style>

    <Style TargetType="{x:Type materialDesign:Card}" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="MaterialDesignToggleButtonWithIcon" BasedOn="{StaticResource MaterialDesignFloatingActionButton}"
           TargetType="{x:Type ToggleButton}" />

</ResourceDictionary>
