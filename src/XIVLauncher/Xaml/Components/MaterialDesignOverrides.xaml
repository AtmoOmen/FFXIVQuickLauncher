<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit">

    <FontFamily x:Key="AppFontFamily">pack://application:,,,/XIVLauncherCN;component/Resources/Fonts/#HarmonyOS Sans SC</FontFamily>

    <Style TargetType="{x:Type FrameworkElement}">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Language" Value="zh-CN" />
    </Style>

    <Style TargetType="{x:Type Window}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="{x:Type UserControl}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="{x:Type Menu}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="{x:Type RichTextBox}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style x:Key="ChangeLogMarkdownStyle" TargetType="{x:Type FlowDocument}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="PagePadding" Value="0,0,8,0" />
        <Style.Resources>
            <Style TargetType="{x:Type Paragraph}">
                <Setter Property="Margin" Value="0,0,0,8" />
                <Style.Triggers>
                    <!-- Headers -->
                    <Trigger Property="Tag" Value="Heading1">
                        <Setter Property="FontSize" Value="32" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                        <Setter Property="Margin" Value="0,24,0,12" />
                    </Trigger>
                    <Trigger Property="Tag" Value="Heading2">
                        <Setter Property="FontSize" Value="28" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                        <Setter Property="Margin" Value="0,20,0,10" />
                    </Trigger>
                    <Trigger Property="Tag" Value="Heading3">
                        <Setter Property="FontSize" Value="24" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                        <Setter Property="Margin" Value="0,16,0,8" />
                    </Trigger>
                    <Trigger Property="Tag" Value="Heading4">
                        <Setter Property="FontSize" Value="22" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                        <Setter Property="Margin" Value="0,12,0,6" />
                    </Trigger>
                    <Trigger Property="Tag" Value="Heading5">
                        <Setter Property="FontSize" Value="16" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                        <Setter Property="Margin" Value="0,8,0,4" />
                    </Trigger>
                    <Trigger Property="Tag" Value="Heading6">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                        <Setter Property="Margin" Value="0,4,0,2" />
                    </Trigger>

                    <!-- ThematicBreak (Horizontal Rule) -->
                    <Trigger Property="Tag" Value="ThematicBreak">
                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="Margin" Value="0,16" />
                    </Trigger>

                    <!-- CodeBlock (Non-AvalonEdit fallback) -->
                    <Trigger Property="Tag" Value="CodeBlock">
                        <Setter Property="FontFamily" Value="Consolas" />
                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Padding" Value="8" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type Section}">
                <Setter Property="Margin" Value="0" />
                <Style.Triggers>
                    <!-- Blockquote -->
                    <Trigger Property="Tag" Value="Blockquote">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                        <Setter Property="BorderThickness" Value="4,0,0,0" />
                        <Setter Property="Padding" Value="16,8" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type List}">
                <Setter Property="Margin" Value="16,0,0,8" />
                <Setter Property="Padding" Value="0" />
            </Style>
            <Style TargetType="{x:Type ListItem}">
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>
            <Style TargetType="{x:Type Span}">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                <Style.Triggers>
                    <!-- Strikethrough -->
                    <Trigger Property="Tag" Value="Strikethrough">
                        <Setter Property="TextDecorations" Value="Strikethrough" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="{x:Type Run}">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                <Style.Triggers>
                    <!-- Inline Code -->
                    <Trigger Property="Tag" Value="Code">
                        <Setter Property="FontFamily" Value="Consolas" />
                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}" />
                        <Setter Property="FontSize" Value="13" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="{x:Type Bold}">
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style TargetType="{x:Type Italic}">
                <Setter Property="FontStyle" Value="Italic" />
            </Style>
            <Style TargetType="{x:Type Hyperlink}">
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                <Setter Property="TextDecorations" Value="None" />
            </Style>
            <Style TargetType="{x:Type Table}">
                <Setter Property="CellSpacing" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="BorderThickness" Value="0,1,0,0" />
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}" />
            </Style>
            <Style TargetType="{x:Type TableRowGroup}" />
            <Style TargetType="{x:Type TableRow}" />
            <Style TargetType="{x:Type TableCell}">
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="Padding" Value="8,8" />
            </Style>
            <Style TargetType="{x:Type BlockUIContainer}">
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>
            <Style TargetType="{x:Type Image}">
                <Setter Property="MaxWidth" Value="520" />
                <Setter Property="Stretch" Value="Uniform" />
                <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
            </Style>
            <Style TargetType="{x:Type avalonEdit:TextEditor}">
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}" />
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
                <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            </Style>
        </Style.Resources>
    </Style>

</ResourceDictionary>
