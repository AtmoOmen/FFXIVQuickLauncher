<UserControl x:Class="XIVLauncher.Windows.Main.LoginCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mahIcon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:transitions="clr-namespace:XIVLauncher.Xaml.Transitions"
             xmlns:constant="clr-namespace:XIVLauncher.Common.Constant;assembly=XIVLauncher.Common"
             xmlns:slides="clr-namespace:XIVLauncher.Windows.Main.Slides"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="280">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="LoginCardSlideResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SocialSiteButtonStyle"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
            </Style>
            <Style x:Key="QuickLinkButtonStyle"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="Height" Value="30" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
            </Style>
            <Style x:Key="PrimaryQuickLinkButtonStyle"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Height" Value="30" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <materialDesign:Card
        Margin="0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        UniformCornerRadius="12"
        materialDesign:ElevationAssist.Elevation="Dp4"
        KeyDown="Card_KeyDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 顶部工具栏 (仅 MainPage / Dashboard 显示) -->
            <Grid Grid.Row="0" Margin="8,8,8,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding ElementName=LoginCardTransitioner, Path=SelectedIndex}"
                                Value="1">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding ElementName=LoginCardTransitioner, Path=SelectedIndex}"
                                Value="4">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Style="{StaticResource HeaderUtilityButtonStyle}"
                            ToolTip="修复"
                            Command="{Binding LoginPage.LoginRepairCommand}">
                        <materialDesign:PackIcon Kind="Wrench"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                    </Button>

                    <Button Style="{StaticResource HeaderUtilityButtonStyle}"
                            ToolTip="完整性检查"
                            Command="{Binding LoginPage.RunIntegrityCheckCommand}">
                        <materialDesign:PackIcon Kind="ShieldCheck"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                    </Button>

                    <Button Style="{StaticResource HeaderUtilityButtonStyle}"
                            ToolTip="更新"
                            Command="{Binding LoginPage.LoginNoStartCommand}">
                        <materialDesign:PackIcon Kind="Update"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button
                        Style="{StaticResource HeaderUtilityButtonStyle}"
                        ToolTip="手动注入"
                        Command="{Binding LoginPage.InjectModeSwitchCommand}"
                        Visibility="{Binding Settings.EnableHooks, Converter={StaticResource BoolToVis}}">
                        <materialDesign:PackIcon Kind="Injection" Width="20" Height="20"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                    </Button>

                    <Button
                        Style="{StaticResource HeaderUtilityButtonStyle}"
                        ToolTip="软件设置"
                        Click="SettingsButton_OnClick">
                        <materialDesign:PackIcon Kind="Gear" Width="20" Height="20"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                    </Button>
                </StackPanel>
            </Grid>

            <materialDesign:Transitioner x:Name="LoginCardTransitioner" Grid.Row="1"
                                         VerticalAlignment="Stretch"
                                         SelectedIndex="{Binding LoginCardTransitionerIndex}">
                <!-- Slide 0: 登录中 -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.ForwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.ForwardWipe>
                    <slides:LoginingSlide />
                </materialDesign:TransitionerSlide>

                <!-- Slide 1: 主登录页 -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.BackwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.BackwardWipe>
                    <slides:MainLoginSlide x:Name="MainLogin" />
                </materialDesign:TransitionerSlide>

                <!-- Slide 2: 扫码登录 -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.BackwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.BackwardWipe>
                    <slides:ScanQRSlide />
                </materialDesign:TransitionerSlide>

                <!-- Slide 3: InjectMode -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.BackwardWipe>
                        <materialDesign:SlideWipe />
                    </materialDesign:TransitionerSlide.BackwardWipe>
                    <slides:InjectSlide />
                </materialDesign:TransitionerSlide>

                <!-- Slide 4: Dashboard -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.ForwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.ForwardWipe>
                    <materialDesign:TransitionerSlide.BackwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.BackwardWipe>
                    <slides:DashboardSlide x:Name="Dashboard" />
                </materialDesign:TransitionerSlide>

                <!-- Slide 5: DC Travel -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.ForwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.ForwardWipe>
                    <materialDesign:TransitionerSlide.BackwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.BackwardWipe>
                    <slides:DCTravelSlide />
                </materialDesign:TransitionerSlide>

                <!-- Slide 6: DC Travel 历史记录 -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.ForwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.ForwardWipe>
                    <materialDesign:TransitionerSlide.BackwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.BackwardWipe>
                    <slides:DCTravelHistorySlide />
                </materialDesign:TransitionerSlide>

                <!-- Slide 7: DC Travel 传送进度 -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.ForwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.ForwardWipe>
                    <materialDesign:TransitionerSlide.BackwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.BackwardWipe>
                    <slides:DCTravelProgressSlide />
                </materialDesign:TransitionerSlide>

                <!-- Slide 8: DC Travel 超域返回 -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.ForwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.ForwardWipe>
                    <materialDesign:TransitionerSlide.BackwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.BackwardWipe>
                    <slides:DCTravelReturnSlide />
                </materialDesign:TransitionerSlide>

                <!-- Slide 9: 账户管理器 -->
                <materialDesign:TransitionerSlide>
                    <materialDesign:TransitionerSlide.ForwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.ForwardWipe>
                    <materialDesign:TransitionerSlide.BackwardWipe>
                        <transitions:StableFadeWipe />
                    </materialDesign:TransitionerSlide.BackwardWipe>
                    <slides:AccountSwitcherSlide x:Name="AccountSwitcher" />
                </materialDesign:TransitionerSlide>
            </materialDesign:Transitioner>

            <!-- 快捷入口（仅 Dashboard 显示） -->
            <StackPanel Grid.Row="2" Margin="16,0,16,12">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=LoginCardTransitioner, Path=SelectedIndex}"
                                         Value="4">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.Column="0"
                            Command="{Binding DashboardPage.OpenDCTravelCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryQuickLinkButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DashboardPage.IsDCTravelUnderMaintenance}"
                                                 Value="True">
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Setter Property="ToolTip">
                                            <Setter.Value>
                                                <ToolTip>
                                                    <TextBlock Text="超域旅行服务维护中, 请稍后再试" FontSize="12" />
                                                </ToolTip>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Rocket" Width="14" Height="14" Margin="0,0,4,0"
                                                     VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="超域传送" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DashboardPage.IsDCTravelUnderMaintenance}"
                                                         Value="True">
                                                <Setter Property="Text" Value="超域传送 (维护中)" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="0" Grid.Column="2"
                            Style="{StaticResource QuickLinkButtonStyle}"
                            Click="PayPageButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClockPlus" Width="14" Height="14" Margin="0,0,4,0"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            <TextBlock Text="购卡充值" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2" Grid.Column="0"
                            Style="{StaticResource QuickLinkButtonStyle}"
                            Click="ShoppingPageButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cart" Width="14" Height="14" Margin="0,0,4,0"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            <TextBlock Text="商城中心" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="OfficialAccountsButton"
                            Grid.Row="2" Grid.Column="2"
                            Style="{StaticResource QuickLinkButtonStyle}">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="OfficialAccountsPopup"
                                                                        Storyboard.TargetProperty="IsOpen">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True" />
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="14" Height="14" Margin="0,0,4,0"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            <TextBlock Text="官方账号" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>

                    <Popup x:Name="OfficialAccountsPopup"
                           Grid.Row="2" Grid.Column="2"
                           AllowsTransparency="True"
                           Placement="Top"
                           PlacementTarget="{Binding ElementName=OfficialAccountsButton}"
                           PopupAnimation="None"
                           StaysOpen="False"
                           VerticalOffset="-6">
                        <materialDesign:Card Background="{DynamicResource MaterialDesign.Brush.Background}"
                                             UniformCornerRadius="8"
                                             materialDesign:ElevationAssist.Elevation="Dp4">
                            <StackPanel Margin="4">
                                <Button Style="{StaticResource SocialSiteButtonStyle}"
                                        Tag="{x:Static constant:Links.SDO_DOUYIN_URL}"
                                        Click="OpenExternalSiteButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <mahIcon:PackIconSimpleIcons Width="16" Height="16" Kind="TikTok"
                                                                     Margin="0,0,8,0" VerticalAlignment="Center"
                                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                        <TextBlock Text="抖音" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SocialSiteButtonStyle}"
                                        Tag="{x:Static constant:Links.SDO_XIAOHONGSHU_URL}"
                                        Click="OpenExternalSiteButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <mahIcon:PackIconSimpleIcons Width="16" Height="16" Kind="Xiaohongshu"
                                                                     Margin="0,0,8,0" VerticalAlignment="Center"
                                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                        <TextBlock Text="小红书" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SocialSiteButtonStyle}"
                                        Tag="{x:Static constant:Links.SDO_WEIBO_URL}"
                                        Click="OpenExternalSiteButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <mahIcon:PackIconSimpleIcons Width="16" Height="16" Kind="SinaWeibo"
                                                                     Margin="0,0,8,0" VerticalAlignment="Center"
                                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                        <TextBlock Text="微博" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SocialSiteButtonStyle}"
                                        Tag="{x:Static constant:Links.SDO_BILIBILI_URL}"
                                        Click="OpenExternalSiteButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <mahIcon:PackIconSimpleIcons Width="16" Height="16" Kind="Bilibili"
                                                                     Margin="0,0,8,0" VerticalAlignment="Center"
                                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                        <TextBlock Text="哔哩哔哩" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:Card>
                    </Popup>
                </Grid>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
