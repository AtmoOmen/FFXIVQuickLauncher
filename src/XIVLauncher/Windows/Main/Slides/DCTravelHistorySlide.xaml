<UserControl x:Class="XIVLauncher.Windows.Main.Slides.DCTravelHistorySlide"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="240">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Windows/Main/LoginCardSlideResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20,0,20,0" VerticalAlignment="Center">
        <StackPanel>
            <StackPanel Visibility="{Binding DCTravelPage.HasNoMigrationOrders, Converter={StaticResource BoolToVis}}"
                        Margin="0,20,0,24" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="History" Width="48" Height="48"
                                         Opacity="0.25" HorizontalAlignment="Center"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                <TextBlock Text="暂无超域旅行历史记录" FontSize="12" FontWeight="SemiBold"
                           Opacity="0.4" Margin="0,12,0,0" HorizontalAlignment="Center" />
                <TextBlock Text="可在上一步选择角色进行超域传送" FontSize="10"
                           Opacity="0.3" Margin="0,4,0,0" HorizontalAlignment="Center" />
            </StackPanel>

            <ListBox ItemsSource="{Binding DCTravelPage.MigrationOrders}"
                     SelectedItem="{Binding DCTravelPage.SelectedOrder}"
                     Visibility="{Binding DCTravelPage.HasMigrationOrders, Converter={StaticResource BoolToVis}}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MaxHeight="260"
                     Margin="0,0,0,12"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MaterialDesign.Brush.Card.Background}" />
                                    <Setter Property="BorderBrush"
                                            Value="{DynamicResource MaterialDesign.Brush.Card.Border}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Padding" Value="10,8" />
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}"
                                            Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                            Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                            <Setter Property="Padding" Value="9,7" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <materialDesign:PackIcon Kind="Account" Width="12" Height="12"
                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                                 VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <TextBlock Text="{Binding RoleName}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CreateTime}"
                                               FontSize="9"
                                               Opacity="0.5"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Border Grid.Row="1"
                                        Background="#08FFFFFF"
                                        CornerRadius="4"
                                        Margin="0,6,0,6"
                                        Padding="6,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SourceAreaName}" FontSize="8" Opacity="0.5"
                                                       HorizontalAlignment="Left" />
                                            <TextBlock Text="{Binding SourceGroupName}" FontSize="10"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                                       Margin="0,1,0,0" HorizontalAlignment="Left" />
                                        </StackPanel>
                                        <materialDesign:PackIcon Grid.Column="1"
                                                                 Kind="ChevronDoubleRight"
                                                                 Width="12" Height="12"
                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                                 VerticalAlignment="Center"
                                                                 HorizontalAlignment="Center"
                                                                 Margin="4,0,4,0" />
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TargetAreaName}" FontSize="8" Opacity="0.5"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding TargetGroupName}" FontSize="10"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                                       Margin="0,1,0,0" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="LightSlateGray" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TravelStatus}" Value="1">
                                                            <Setter Property="Fill" Value="MediumSeaGreen" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock FontSize="10" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="已返回" />
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                                                    <Setter Property="Opacity" Value="0.6" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TravelStatus}" Value="1">
                                                            <Setter Property="Text" Value="已抵达" />
                                                            <Setter Property="Foreground" Value="MediumSeaGreen" />
                                                            <Setter Property="Opacity" Value="1.0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="16"
                        Height="36" FontSize="12"
                        Command="{Binding DCTravelPage.TravelBackCommand}"
                        IsEnabled="{Binding DCTravelPage.IsNotLoading}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeftBold" Width="16" Height="16" Margin="0,0,6,0"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="超域返回" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="16"
                        Height="36" FontSize="12"
                        Command="{Binding DCTravelPage.RefreshOrdersCommand}"
                        IsEnabled="{Binding DCTravelPage.IsNotLoading}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="刷新" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding DCTravelPage.BackToTravelCommand}"
                    Margin="0,0,0,4" Height="24" Padding="8,0"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="12" Height="12" Margin="0,0,4,0"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="返回" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
