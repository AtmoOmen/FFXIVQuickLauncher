<UserControl
    x:Class="XIVLauncher.Windows.SettingsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:addon="clr-namespace:XIVLauncher.Common.Addon;assembly=XIVLauncher.Common"
    xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
    xmlns:components="clr-namespace:XIVLauncher.Xaml.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dragablz="http://dragablz.net/winfx/xaml/dragablz"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
    d:DataContext="{d:DesignInstance viewModel:SettingsControlViewModel}"
    Background="{DynamicResource MaterialDesignPaper}"
    DataContextChanged="SettingsControl_OnDataContextChanged"
    TextElement.FontWeight="Bold"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    mc:Ignorable="d">
    <Grid SnapsToDevicePixels="True" ClipToBounds="True">
        <dragablz:TabablzControl
            x:Name="SetupTabControl"
            FixedHeaderCount="6"
            IsEnabled="True"
            Style="{StaticResource MaterialDesignTabablzControlStyle}">
            <dragablz:TabablzControl.HeaderSuffixContent>
                    <Button
                        Click="AcceptButton_Click"
                        Margin="6 0 10 0"
                        Padding="10 6 10 6"
                        HorizontalAlignment="Right"
                        HorizontalContentAlignment="Center"
                        Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="12" Height="12" Kind="KeyboardBackspace" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
            </dragablz:TabablzControl.HeaderSuffixContent>

            <!-- Tab: 游戏 (Game) -->
            <TabItem Header="游戏">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="游戏位置" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" />

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="游戏目录" Foreground="{DynamicResource MaterialDesignBody}" />
                            <components:FolderEntry Grid.Row="1" Margin="0,8,0,0" Description="选择文件夹" Foreground="{DynamicResource MaterialDesignBody}" Text="{Binding GamePath, UpdateSourceTrigger=PropertyChanged}" />  
                            <TextBlock Grid.Row="2" Margin="0,4,0,0" Foreground="Red" Text="{Binding GamePathWarningMessage}" Visibility="{Binding GamePathWarningVisibility}" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                            <Button Content="检查完整性" Style="{StaticResource MaterialDesignOutlinedButton}" ToolTip="对游戏文件执行完整性检查" Click="RunIntegrityCheck_OnClick" IsEnabled="{Binding IsRunIntegrityCheckPossible}" Margin="0,0,16,0" />
                            <Button Content="生成哈希数据" Style="{StaticResource MaterialDesignOutlinedButton}" ToolTip="遍历游戏文件并生成 Hash 数据" Click="GenerateIntegrityCheck_OnClick" IsEnabled="{Binding IsRunIntegrityCheckPossible}" />
                        </StackPanel>

                        <Separator Margin="0,0,0,24" />
                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="更新设置" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" />

                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="安装更新前先进行确认" FontSize="15" VerticalAlignment="Center" />
                            <ToggleButton Foreground="{DynamicResource MaterialDesignBody}" Grid.Column="1" IsChecked="{Binding AskBeforePatching}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="保留已下载的补丁包" FontSize="15" VerticalAlignment="Center" />
                            <ToggleButton Foreground="{DynamicResource MaterialDesignBody}" Grid.Column="1" IsChecked="{Binding KeepPatches}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </Grid>

                        <Separator Margin="0,8,0,24" />

                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="存储目录" FontSize="15" Margin="0,0,0,8" />
                            <components:FolderEntry Description="选择文件夹" Text="{Binding PatchPath, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource MaterialDesignBody}" />
                        </StackPanel>

                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" MinWidth="150" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="速度限制" FontSize="15" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBox Width="80" Text="{Binding SpeedLimitMb}" Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center" />
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="MB/s" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" MinWidth="150" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="下载方式" FontSize="15" />
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="推荐选择 ARIA（HTTP）" Opacity="0.7" FontSize="12" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding PatchAcquisitionIndex}" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBody}">
                                <ComboBoxItem Content=".NET（HTTP）" />
                                <ComboBoxItem Content="ARIA（HTTP）" />
                            </ComboBox>
                        </Grid>

                        <Separator Margin="0,8,0,24" />

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="GitHub Access Token" FontSize="15" />
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="用于启动器更新用, 建议填入不包含任何权限的令牌" Opacity="0.7" FontSize="12" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="200" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBody}" Text="{Binding GitHubToken, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Token" />
                                <Button Content="查询额度" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding IdentifyTokenCommand}" Margin="16,0,0,0" />
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: 启动 (Start - Combined Launcher & Auto-start) -->
            <TabItem Header="启动">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="一般" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" />

                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" MinWidth="150" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="游戏 DPI 修正" FontSize="15" Foreground="{DynamicResource MaterialDesignBody}" />
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="若游戏界面缩放异常, 可尝试切换本项" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" VerticalAlignment="Center" SelectedIndex="{Binding DpiAwarenessIndex}" Foreground="{DynamicResource MaterialDesignBody}">
                                <ComboBoxItem Content="启用" />
                                <ComboBoxItem Content="禁用" />
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" MinWidth="250" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="额外启动参数" FontSize="15" Foreground="{DynamicResource MaterialDesignBody}" />
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="附加到游戏进程的命令行参数" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBox Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBody}" Text="{Binding LaunchArgs, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="参数" />
                        </Grid>

                        <Separator Margin="0,0,0,24" />

                        <materialDesign:Card Background="{DynamicResource MaterialDesignBackground}" Foreground="OrangeRed" Padding="16" Margin="0,0,0,24" Visibility="{c:Binding LauncherLanguageNoticeVisible, FalseToVisibility=Collapsed}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="修改启动器语言后需要重新启动 XIVLauncher 才会生效" VerticalAlignment="Center" />
                            </StackPanel>
                        </materialDesign:Card>

                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="安全" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" />

                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" MinWidth="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="凭据加密方式" FontSize="15" />
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="自动登录所用到的凭据在本地的加密方式" Opacity="0.7" FontSize="12" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBody}" DisplayMemberPath="Display" ItemsSource="{Binding CredTypeOptions}" SelectedItem="{Binding SelectedCredTypeOption}">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="共享设备信息" FontSize="15" />
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="未设置独立设备信息的账号将使用此处设置的共享设备信息" Opacity="0.7" FontSize="12" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="管理" Style="{StaticResource MaterialDesignOutlinedButton}" Click="SharedDeviceProfileButton_Click" Width="100" />
                        </Grid>

                        <Separator Margin="0,8,0,24" />

                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="附加程序" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,8" />
                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="添加在此处的程序会在游戏启动/结束时一并启动" Opacity="0.7" Margin="0,0,0,16" />

                        <materialDesign:Card Padding="0" Margin="0,0,0,16">
                            <ListView x:Name="AddonListView" ScrollViewer.VerticalScrollBarVisibility="Disabled" ItemsSource="{Binding AddonEntries}" MouseUp="AddonListView_OnMouseUp" PreviewMouseRightButtonDown="AddonListView_OnPreviewMouseRightButtonDown" SelectedItem="{Binding SelectedAddonEntry}">
                                <ListView.ContextMenu>
                                    <ContextMenu StaysOpen="True" Style="{StaticResource MaterialDesignContextMenu}">
                                        <ContextMenu.Resources>
                                            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource MaterialDesignMenuItem}" />
                                            <Style TargetType="{x:Type Separator}" BasedOn="{StaticResource MaterialDesignSeparator}" />
                                        </ContextMenu.Resources>
                                        <MenuItem Command="{Binding RemoveSelectedAddonCommand}" Foreground="{DynamicResource MaterialDesignBody}" Header="移除" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.ItemTemplate>
                                    <DataTemplate DataType="{x:Type addon:AddonEntry}">
                                        <StackPanel Orientation="Horizontal" Margin="8">
                                            <CheckBox Foreground="{DynamicResource MaterialDesignBody}" IsChecked="{Binding IsEnabled}" />
                                            <TextBlock Margin="16,0,0,0" Foreground="{DynamicResource MaterialDesignBody}" Text="{Binding Addon.Name}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </materialDesign:Card>

                        <Button HorizontalAlignment="Right" Command="{Binding AddAddonCommand}" Content="新增" Style="{StaticResource MaterialDesignRaisedButton}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: Dalamud -->
            <TabItem Header="Dalamud">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="启用 Dalamud" FontSize="15" />
                                <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="启用后, 可在游戏内使用 /xlhelp 查看相关可用命令" Opacity="0.7" FontSize="12" />
                            </StackPanel>
                            <ToggleButton Foreground="{DynamicResource MaterialDesignBody}" Grid.Column="1" x:Name="EnableHooksCheckBox" IsChecked="{Binding EnableHooks}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </Grid>

                        <StackPanel IsEnabled="{Binding ElementName=EnableHooksCheckBox, Path=IsChecked}">      
                            <Separator Margin="0,8,0,24" />
                            <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="注入设置" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" />

                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="注入延迟" FontSize="15" />
                                    <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="调整 Dalamud 挂载到游戏进程的时间" Opacity="0.7" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBox Width="70" Text="{Binding DalamudInjectionDelayMs}" Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center" />
                                    <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="ms" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="加载方式" FontSize="15" Margin="0,0,0,8" />
                            <RadioButton x:Name="EntryPointDalamudLoadMethodRadioButton" Content="新版：兼容部分需要更早加载的插件和辅助软件" GroupName="dalamudLoadMethod" IsChecked="{Binding UseEntryPointLoadMethod}" ToolTip="通过入口点重写方式加载 Dalamud, 通常兼容性更好。" Margin="0,0,0,8" Foreground="{DynamicResource MaterialDesignBody}" />
                            <RadioButton x:Name="DllInjectDalamudLoadMethodRadioButton" Content="传统：旧版 DLL 注入方式, 部分环境下更稳定" GroupName="dalamudLoadMethod" IsChecked="{Binding UseDllInjectLoadMethod}" ToolTip="通过 DLL 注入方式加载 Dalamud, 兼容性取决于本机环境。" Margin="0,0,0,16" Foreground="{DynamicResource MaterialDesignBody}" />

                            <Separator Margin="0,8,0,24" />
                            <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="实验性功能" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" />

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="游戏内超域传送" FontSize="15" />
                                    <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Opacity="0.7" FontSize="12" TextWrapping="Wrap">
                                        <Run Text="额外支持游戏内超域传送, 需要同时安装并启用 DCTravelerX 插件" />
                                    </TextBlock>
                                </StackPanel>
                                <ToggleButton Foreground="{DynamicResource MaterialDesignBody}" Grid.Column="1" IsChecked="{Binding EnableDcTravel}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: 关于 (About) -->
            <TabItem Header="关于">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource MaterialDesignBody}" x:Name="VersionLabel" Text="{Binding VersionLabelText}" FontSize="24" FontWeight="Bold" Cursor="Hand" MouseUp="VersionLabel_OnMouseUp" Margin="0,0,0,4" />
                            <TextBlock Text="本软件基于 GPLv3 协议发布" Cursor="Hand" MouseUp="LicenseText_OnMouseUp" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,24" TextDecorations="Underline" />        

                            <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="作者：goat" FontSize="14" Margin="0,0,0,4" />
                            <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="特别鸣谢：Mino、sky、LeonBlade、Wintermute、Zyian、Roy、Meli、Aida Enna、Aireil、kizer 与 the angry paissa artist" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,24" />

                            <WrapPanel Margin="0,0,0,24">
                                <Button x:Name="DiscordButton" Style="{DynamicResource MaterialDesignOutlinedButton}" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Discord" VerticalAlignment="Center" />   
                                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Margin="8,0,0,0" VerticalAlignment="Center" Text="Discord" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenGitHubCommand}" Style="{DynamicResource MaterialDesignOutlinedButton}" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Github" VerticalAlignment="Center" />    
                                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Margin="8,0,0,0" VerticalAlignment="Center" Text="GitHub" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenOriginalLauncherCommand}" Style="{DynamicResource MaterialDesignOutlinedButton}" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Launch" VerticalAlignment="Center" />    
                                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Margin="8,0,0,0" VerticalAlignment="Center" Text="官方启动器" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenBackupToolCommand}" Style="{DynamicResource MaterialDesignOutlinedButton}" Visibility="Collapsed" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Wrench" VerticalAlignment="Center" />    
                                        <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Margin="8,0,0,0" VerticalAlignment="Center" Text="打开备份工具" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <Separator Margin="0,0,0,24" />

                            <Button Command="{Binding OpenAdvancedSettingsCommand}" Style="{DynamicResource MaterialDesignFlatButton}" HorizontalAlignment="Left" Opacity="0.7">
                                <Button.ToolTip>
                                    <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Text="这些设置仅适合高级用户。除非清楚每项设置的含义, 否则请勿随意修改。" />
                                </Button.ToolTip>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Settings" VerticalAlignment="Center" />      
                                    <TextBlock Foreground="{DynamicResource MaterialDesignBody}" Margin="8,0,0,0" VerticalAlignment="Center" Text="高级设置" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Image Grid.Column="1" Width="180" Height="180" Margin="32,0,0,0" VerticalAlignment="Top" MouseUp="Logo_OnMouseUp" Opacity="0.8" RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,,/Resources/logo.png" Cursor="Hand" />
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </dragablz:TabablzControl>
    </Grid>
</UserControl>
