<Window
    x:Class="XIVLauncher.Windows.AccountSwitcher"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:accounts="clr-namespace:XIVLauncher.Accounts"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
    Title="账户切换"
    Width="280"
    SizeToContent="Height"
    AllowsTransparency="True"
    Background="Transparent"
    Deactivated="AccountSwitcher_OnDeactivated"
    Icon="pack://application:,,,/Resources/dalamud_icon.ico"
    ResizeMode="NoResize"
    TextElement.FontWeight="Medium"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewModel:AccountSwitcherViewModel}">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,15,0,-15" To="0,0,0,0" Duration="0:0:0.25">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid Margin="10,10,10,10">
        <materialDesign:Card Background="{DynamicResource MaterialDesignPaper}" 
                             UniformCornerRadius="8" 
                             Margin="0">
            <Grid Margin="12,12,12,12">
                <ListView
                    x:Name="AccountListView"
                    AllowDrop="True"
                    BorderThickness="0"
                    Drop="AccountListView_OnDrop"
                    ItemsSource="{Binding Entries}"
                    MouseUp="AccountListView_OnMouseUp"
                    PreviewMouseLeftButtonDown="AccountListView_OnPreviewMouseLeftButtonDown"
                    PreviewMouseRightButtonDown="AccountListView_OnPreviewMouseRightButtonDown"
                    PreviewMouseMove="AccountListView_OnPreviewMouseMove"
                    SelectionMode="Single"
                    MaxHeight="450"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    SelectedItem="{Binding SelectedEntry}">
                    <ListView.ContextMenu>
                        <ContextMenu Language="zh-CN"
                                     Style="{StaticResource MaterialDesignContextMenu}">
                            <ContextMenu.Resources>
                                <Style TargetType="{x:Type MenuItem}"
                                       BasedOn="{StaticResource MaterialDesignMenuItem}" />
                                <Style TargetType="{x:Type Separator}"
                                       BasedOn="{StaticResource MaterialDesignSeparator}" />
                            </ContextMenu.Resources>
                            <MenuItem
                                Command="{Binding SetProfilePictureCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="设置头像" />
                            <MenuItem
                                Command="{Binding SetNoteCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="设置备注" />
                            <MenuItem
                                Command="{Binding ConfigureDeviceProfileCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="设置设备信息" />
                            <Separator />
                            <MenuItem
                                Command="{Binding CreateDesktopShortcutCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="创建桌面快捷方式" />
                            <Separator />
                            <MenuItem
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="不保存密码"
                                IsCheckable="True"
                                IsChecked="{Binding IsSelectedAccountPasswordNotSaved, Mode=TwoWay}" />
                            <Separator />
                            <MenuItem
                                Command="{Binding RemoveAccountCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="移除" />
                        </ContextMenu>
                    </ListView.ContextMenu>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Margin" Value="0,0,0,4" />
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border
                                            x:Name="ItemBorder"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                            <ContentPresenter
                                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A000000" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#26000000" />
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:Name="SingleLineDataTemplate" DataType="accounts:AccountSwitcherEntry">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="38" Height="38" ClipToBounds="True" CornerRadius="6" Grid.Column="0">
                                    <Image
                                        Width="38"
                                        Height="38"
                                        Source="{Binding ProfileImage}"
                                        Stretch="UniformToFill" />
                                </Border>
                                
                                <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Text="{Binding Account.DisplayName}" FontSize="14" TextTrimming="CharacterEllipsis" />

                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Height="18" Width="18" Margin="4,0,0,0" Opacity="0.7">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Account.IsWeGame}" Value="true">
                                                        <Setter Property="Kind" Value="Qqchat" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Account.IsWeGame}" Value="false">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>

                                    <materialDesign:PackIcon Height="18" Width="18" Margin="4,0,0,0" Opacity="0.7">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Account.AutoLogin}" Value="True">
                                                        <Setter Property="Kind" Value="AccountKeyOutline" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Account.AutoLogin}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>