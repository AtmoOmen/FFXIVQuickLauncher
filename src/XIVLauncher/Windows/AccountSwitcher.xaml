<Window
    x:Class="XIVLauncher.Windows.AccountSwitcher"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:accounts="clr-namespace:XIVLauncher.Accounts"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
    Title="账户切换"
    Width="269.186"
    Height="400"
    AllowsTransparency="True"
    Background="Transparent"
    Deactivated="AccountSwitcher_OnDeactivated"
    Icon="pack://application:,,,/Resources/dalamud_icon.ico"
    ResizeMode="NoResize"
    TextElement.FontWeight="Bold"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewModel:AccountSwitcherViewModel}">
    <Grid Margin="0,0,0,0">
        <materialDesign:Card Background="{DynamicResource MaterialDesignPaper}" Height="390" Margin="0,0,10,0">
            <StackPanel Margin="16,16,10,0">
                
                <Button
                    Margin="0,0,0,12"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Command="{Binding ConfigureSharedDeviceProfileCommand}"
                    Content="设备信息" />
                
                <Separator />
                
                <ListView
                    Margin="0,12,0,0"
                    x:Name="AccountListView"
                    MaxHeight="330"
                    AllowDrop="True"
                    Drop="AccountListView_OnDrop"
                    ItemsSource="{Binding Entries}"
                    MouseUp="AccountListView_OnMouseUp"
                    PreviewMouseLeftButtonDown="AccountListView_OnPreviewMouseLeftButtonDown"
                    PreviewMouseRightButtonDown="AccountListView_OnPreviewMouseRightButtonDown"
                    PreviewMouseMove="AccountListView_OnPreviewMouseMove"
                    SelectionMode="Single"
                    SelectedItem="{Binding SelectedEntry}">
                    <ListView.ContextMenu>
                        <ContextMenu Language="zh-CN"
                                     Style="{StaticResource MaterialDesignContextMenu}">
                            <ContextMenu.Resources>
                                <Style TargetType="{x:Type MenuItem}"
                                       BasedOn="{StaticResource MaterialDesignMenuItem}" />
                                <Style TargetType="{x:Type Separator}"
                                       BasedOn="{StaticResource MaterialDesignSeparator}" />
                            </ContextMenu.Resources>
                            <MenuItem
                                Command="{Binding SetProfilePictureCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="设置头像" />
                            <MenuItem
                                Command="{Binding SetNoteCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="设置备注" />
                            <MenuItem
                                Command="{Binding ConfigureDeviceProfileCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="设置设备信息" />
                            <Separator />
                            <MenuItem
                                Command="{Binding CreateDesktopShortcutCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="创建桌面快捷方式" />
                            <Separator />
                            <MenuItem
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="不保存密码"
                                IsCheckable="True"
                                IsChecked="{Binding IsSelectedAccountPasswordNotSaved, Mode=TwoWay}" />
                            <Separator />
                            <MenuItem
                                Command="{Binding RemoveAccountCommand}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Header="移除" />
                        </ContextMenu>
                    </ListView.ContextMenu>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Margin" Value="0,0,0,6" />
                            <Setter Property="Padding" Value="6" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border
                                            x:Name="ItemBorder"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4">
                                            <ContentPresenter
                                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#12000000" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#16FFFFFF" />
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:Name="SingleLineDataTemplate" DataType="accounts:AccountSwitcherEntry">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Height="42" Orientation="Horizontal">
                                    <Border Width="42" Height="42" ClipToBounds="True" CornerRadius="4">
                                        <Image
                                            Width="42"
                                            Height="42"
                                            Source="{Binding ProfileImage}"
                                            Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                                               Text="{Binding Account.DisplayName}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Height="20" Width="20" HorizontalAlignment="Right"
                                                             VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Account.IsWeGame}" Value="true">
                                                        <Setter Property="Kind" Value="Qqchat" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Account.IsWeGame}" Value="false">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>

                                    <materialDesign:PackIcon Height="20" Width="20" HorizontalAlignment="Right"
                                                             VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Account.AutoLogin}" Value="True">
                                                        <Setter Property="Kind" Value="AccountKeyOutline" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Account.AutoLogin}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
