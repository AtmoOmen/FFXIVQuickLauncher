<Window x:Class="XIVLauncher.Windows.GameClientFileTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
        mc:Ignorable="d"
        Title="客户端文件任务"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/dalamud_icon.ico"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Width="360"
        SizeToContent="Height"
        Closing="GameClientFileTaskWindow_OnClosing"
        d:DataContext="{d:DesignInstance viewModel:GameClientFileTaskWindowViewModel}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <materialDesign:Card Background="{DynamicResource MaterialDesign.Brush.Background}" Margin="0,0,10,0">
            <StackPanel Margin="16,16,16,16">
                <TextBlock Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Text="{Binding Title}" />
                <TextBlock Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                           Margin="0,10,0,0"
                           TextAlignment="Center"
                           Text="{Binding PhaseText}" />
                <TextBlock Foreground="DarkGray"
                           Margin="0,8,0,0"
                           TextAlignment="Center"
                           Text="{Binding DetailText}"
                           TextWrapping="Wrap" />
                <ProgressBar Margin="0,12,0,0"
                             Height="5"
                             Value="{Binding Progress, Mode=OneWay}"
                             IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}" />
                <ItemsControl ItemsSource="{Binding Items, Mode=OneWay}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                           Text="{Binding Title}"
                                           TextWrapping="Wrap" />
                                <ProgressBar Margin="0,6,0,0"
                                             Height="4"
                                             Value="{Binding Progress, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                           Margin="0,4,0,0"
                           TextAlignment="Center"
                           Text="{Binding StatusText}"
                           TextWrapping="Wrap" />
                <TextBlock Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                           Margin="0,2,0,0"
                           TextAlignment="Center"
                           Text="{Binding SpeedText}"
                           TextWrapping="Wrap" />
                <TextBlock Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                           Margin="0,2,0,0"
                           TextAlignment="Center"
                           Text="{Binding EtaText}"
                           TextWrapping="Wrap" />
                <UniformGrid Margin="0,14,0,0" Rows="1" Columns="3">
                    <Button Margin="0,0,8,0"
                            Content="{Binding PrimaryButtonText}"
                            Command="{Binding PrimaryButtonCommand}"
                            IsEnabled="{Binding IsPrimaryButtonEnabled, Mode=OneWay}"
                            Visibility="{Binding IsPrimaryButtonVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Margin="0,0,8,0"
                            Content="{Binding SecondaryButtonText}"
                            Command="{Binding SecondaryButtonCommand}"
                            IsEnabled="{Binding IsSecondaryButtonEnabled, Mode=OneWay}"
                            Visibility="{Binding IsSecondaryButtonVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="{Binding CloseButtonText}"
                            Command="{Binding CloseButtonCommand}"
                            IsEnabled="{Binding IsCloseButtonEnabled, Mode=OneWay}"
                            Visibility="{Binding IsCloseButtonVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </UniformGrid>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
