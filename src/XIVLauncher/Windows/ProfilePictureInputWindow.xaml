<Window
    x:Class="XIVLauncher.Windows.ProfilePictureInputWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
    Title="头像设置"
    Width="560"
    Height="320"
    Background="{DynamicResource MaterialDesignPaper}"
    Icon="pack://application:,,,/Resources/dalamud_icon.ico"
    ResizeMode="NoResize"
    TextElement.FontWeight="Bold"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d" d:DataContext="{d:DesignInstance viewModel:ProfilePictureInputWindowViewModel}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Text="请选择本地图片或图标文件作为账号头像。头像会复制到启动器本地目录，后续可随时替换或清除。"
            TextWrapping="Wrap" />

        <Border
            Grid.Row="1"
            Margin="0,16,0,0"
            Padding="16"
            Background="#12000000"
            BorderBrush="#24FFFFFF"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="104"
                    Height="104"
                    Background="#1A000000"
                    BorderBrush="#30FFFFFF"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Stretch">
                    <TextBlock Text="支持格式：PNG、JPG、JPEG、BMP、GIF、ICO" />

                    <TextBox
                        Margin="0,12,0,0"
                        IsReadOnly="True"
                        Text="{Binding SelectedFilePath}" />

                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                        <Button
                            MinWidth="96"
                            Margin="0,0,12,0"
                            Click="BrowseButton_OnClick"
                            Content="选择文件" />
                        <Button
                            MinWidth="96"
                            Click="ClearButton_OnClick"
                            Content="清除头像"
                            IsEnabled="{Binding HasSelectedFile}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel
            Grid.Row="2"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                MinWidth="88"
                Margin="0,0,12,0"
                Click="ConfirmButton_OnClick"
                Content="确定" />
        </StackPanel>
    </Grid>
</Window>
