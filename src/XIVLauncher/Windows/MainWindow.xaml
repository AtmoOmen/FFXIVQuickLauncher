                                                <Path Width="16"
                                                      Height="16"
                                                      Stretch="Uniform"
                                                      Fill="{DynamicResource PrimaryHueMidBrush}"
                                                      Data="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" />
                                            </Button>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                ToolTip="启动器设置"
                                                Command="{x:Static materialDesign:Transitioner.MovePreviousCommand}"
                                                Width="32" Height="32" Padding="4"
                                                Focusable="False" Cursor="Hand">
                                            <materialDesign:PackIcon Kind="Gear" Width="20" Height="20" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        </Button>
                                    </Grid>

                                    <materialDesign:Transitioner x:Name="LoginCardTransitioner" Grid.Row="1" VerticalAlignment="Stretch" SelectedIndex="{Binding LoginCardTransitionerIndex}">
                                        <materialDesign:TransitionerSlide>
                                            <materialDesign:TransitionerSlide.ForwardWipe>
                                                <materialDesign:FadeWipe />
                                            </materialDesign:TransitionerSlide.ForwardWipe>

                                            <Grid Margin="24,0,24,0" VerticalAlignment="Center">
                                                <StackPanel>
                                                    <ProgressBar x:Name="ProgressBar"
                                                                 Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                                 Value="0"
                                                                 IsIndeterminate="True" 
                                                                 Height="48" Width="48" 
                                                                 Margin="0,0,0,16" 
                                                                 HorizontalAlignment="Center" />
                                                    <TextBlock Text="正在登录…"
                                                               HorizontalAlignment="Center"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,8" />
                                                    <TextBlock Text="{Binding LoginMessage}"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,24" />
                                                    <Button Content="取消登录"
                                                            Command="{Binding Path=LoginCancelCommand}"
                                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                                            materialDesign:ButtonAssist.CornerRadius="16"
                                                            HorizontalAlignment="Center"
                                                            Width="120"
                                                            ToolTip="取消登录" />
                                                </StackPanel>
                                            </Grid>
                                        </materialDesign:TransitionerSlide>

                                        <materialDesign:TransitionerSlide>
                                            <materialDesign:TransitionerSlide.BackwardWipe>
                                                <materialDesign:FadeWipe />
                                            </materialDesign:TransitionerSlide.BackwardWipe>

                                            <Grid Margin="20,0,20,0" VerticalAlignment="Center">
                                                <StackPanel>
                                                    <!--  Login Type & Area  -->
                                                    <ComboBox x:Name="LoginTypeSelection"
                                                              materialDesign:HintAssist.Hint="登录方式"
                                                              materialDesign:HintAssist.IsFloating="False"
                                                              SelectedItem="{Binding Path=LoginTypeOption}"
                                                              SelectedValuePath="LoginType"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectionChanged="LoginTypeSelection_OnSelectionChanged"
                                                              Margin="0,0,0,6" />
                                                              
                                                    <ListBox x:Name="ServerSelection"
                                                             ItemsSource="{Binding Path=LoginAreas}"
                                                             SelectedIndex="{Binding Path=AreaIndex, Mode=OneWayToSource}"
                                                             SelectedItem="{Binding Path=Area}"
                                                             SelectedValuePath="AreaID"
                                                             Margin="0,0,0,6">
                                                        <ListBox.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <UniformGrid Rows="1" />
                                                            </ItemsPanelTemplate>
                                                        </ListBox.ItemsPanel>
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                                <Setter Property="Cursor" Value="Hand" />
                                                                <Setter Property="Padding" Value="0" />
                                                                <Setter Property="Margin" Value="2,0" />
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ListBoxItem">
                                                                            <Grid>
                                                                                <Border x:Name="Bg" Background="Transparent" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}" />
                                                                                <Border x:Name="ActiveBg" Background="{DynamicResource PrimaryHueMidBrush}" CornerRadius="4" Opacity="0" />
                                                                                <TextBlock x:Name="Txt" Text="{Binding AreaName}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" Padding="0,4" Foreground="{DynamicResource MaterialDesignBody}" />
                                                                            </Grid>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsSelected" Value="True">
                                                                                    <Trigger.EnterActions>
                                                                                        <BeginStoryboard>
                                                                                            <Storyboard>
                                                                                                <DoubleAnimation Storyboard.TargetName="ActiveBg" Storyboard.TargetProperty="Opacity" To="0.15" Duration="0:0:0.15" />
                                                                                            </Storyboard>
                                                                                        </BeginStoryboard>
                                                                                    </Trigger.EnterActions>
                                                                                    <Trigger.ExitActions>
                                                                                        <BeginStoryboard>
                                                                                            <Storyboard>
                                                                                                <DoubleAnimation Storyboard.TargetName="ActiveBg" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
                                                                                            </Storyboard>
                                                                                        </BeginStoryboard>
                                                                                    </Trigger.ExitActions>
                                                                                    <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                                                                                    <Setter TargetName="Txt" Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}" />
                                                                                    <Setter TargetName="Txt" Property="FontWeight" Value="Bold" />
                                                                                </Trigger>
                                                                                <MultiTrigger>
                                                                                    <MultiTrigger.Conditions>
                                                                                        <Condition Property="IsMouseOver" Value="True" />
                                                                                        <Condition Property="IsSelected" Value="False" />
                                                                                    </MultiTrigger.Conditions>
                                                                                    <MultiTrigger.EnterActions>
                                                                                        <BeginStoryboard>
                                                                                            <Storyboard>
                                                                                                <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.15" />
                                                                                            </Storyboard>
                                                                                        </BeginStoryboard>
                                                                                    </MultiTrigger.EnterActions>
                                                                                    <MultiTrigger.ExitActions>
                                                                                        <BeginStoryboard>
                                                                                            <Storyboard>
                                                                                                <DoubleAnimation Storyboard.TargetName="Bg" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                                                                            </Storyboard>
                                                                                        </BeginStoryboard>
                                                                                    </MultiTrigger.ExitActions>
                                                                                </MultiTrigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                    </ListBox>

                                                    <!--  Credentials  -->
                                                    <TextBox x:Name="LoginUsername"
                                                             materialDesign:HintAssist.Hint="账号"
                                                             materialDesign:HintAssist.IsFloating="False"
                                                             TextWrapping="Wrap"
                                                             TextChanged="LoginUsername_OnTextChanged"
                                                             Text="{Binding Username}" 
                                                             Cursor="IBeam"
                                                             Margin="0,0,0,6" />

                                                    <PasswordBox x:Name="LoginPassword"
                                                                 materialDesign:HintAssist.Hint="密码"
                                                                 materialDesign:HintAssist.IsFloating="False"
                                                                 PasswordChanged="LoginPassword_OnPasswordChanged"
                                                                 Cursor="IBeam"
                                                                 Margin="0,0,0,8" />

                                                    <!--  Options  -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                                                        <CheckBox x:Name="FastLoginCheckBox"
                                                                  Content="快速登录"
                                                                  IsChecked="{Binding IsFastLogin}"
                                                                  ToolTip="勾选后, 在登录时会自动保存账号信息, 以供下次快速登录"
                                                                  Margin="0,0,16,0" />
                                                        <CheckBox x:Name="ReadWeGameInfoCheckBox"
                                                                  Content="读取登录信息"
                                                                  Visibility="Collapsed"
                                                                  ToolTip="从 WeGame 版游戏中读取登录信息"
                                                                  IsChecked="{Binding IsReadWegameInfo}" />
                                                    </StackPanel>

                                                    <!--  Actions  -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <Button x:Name="LoginButton"
                                                                Grid.Column="0"
                                                                Content="登  录"
                                                                Command="{Binding Path=StartLoginCommand}"
                                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                                materialDesign:ButtonAssist.CornerRadius="16"
                                                                Height="32"
                                                                FontSize="13">
                                                            <Button.ContextMenu>
                                                                <ContextMenu Language="zh-CN"
                                                                             Style="{StaticResource LoginActionContextMenuStyle}">
                                                                    <ContextMenu.Resources>
                                                                        <Style TargetType="{x:Type MenuItem}"
                                                                               BasedOn="{StaticResource LoginActionMenuItemStyle}" />
                                                                        <Style TargetType="{x:Type Separator}"
                                                                               BasedOn="{StaticResource LoginActionSeparatorStyle}" />
                                                                    </ContextMenu.Resources>
                                                                    <MenuItem Header="修复" Command="{Binding Path=LoginRepairCommand}" />
                                                                    <MenuItem Header="更新" Command="{Binding Path=LoginNoStartCommand}" />
                                                                    <Separator />
                                                                    <MenuItem Header="其他启动方式">
                                                                        <MenuItem Header="无 Dalamud" Command="{Binding Path=LoginNoDalamudCommand}" />
                                                                        <MenuItem Header="禁用插件" Command="{Binding Path=LoginNoPluginsCommand}" />
                                                                        <MenuItem Header="禁用第三方插件" Command="{Binding Path=LoginNoThirdCommand}" />
                                                                        <Separator />
                                                                        <MenuItem Header="调试用假启动" Command="{Binding Path=FakeStartCommand}" />
                                                                    </MenuItem>
                                                                </ContextMenu>
                                                            </Button.ContextMenu>
                                                        </Button>

                                                        <Button x:Name="AccountSwitcherButton"
                                                                Grid.Column="2"
                                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                materialDesign:ButtonAssist.CornerRadius="16"
                                                                Width="32" Height="32" Padding="0"
                                                                ToolTip="账户管理器"
                                                                Click="AccountSwitcherButton_OnClick">
                                                            <materialDesign:PackIcon Kind="AccountGroup" Width="16" Height="16" />
                                                        </Button>
                                                    </Grid>
                                                    
                                                    <!-- Inject Mode Toggle -->
                                                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                            Command="{Binding Path=InjectModeSwitchCommand}"
                                                            Margin="0,4,0,0" Height="24" Padding="8,0"
                                                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                            Visibility="{Binding Settings.EnableHooks, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            ToolTip="手动注入至已启动的游戏进程">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="Injection" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="手动注入" FontSize="11" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </materialDesign:TransitionerSlide>

                                        <materialDesign:TransitionerSlide>
                                            <materialDesign:TransitionerSlide.BackwardWipe>
                                                <materialDesign:FadeWipe />
                                            </materialDesign:TransitionerSlide.BackwardWipe>

                                            <Grid Margin="24,12,24,8" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Text="扫码登录" 
                                                           HorizontalAlignment="Center" 
                                                           FontSize="16" 
                                                           FontWeight="Bold" 
                                                           Margin="0,0,0,8" />
                                                <TextBlock Grid.Row="1"
                                                           Text="请打开手机叨鱼应用程序扫码登录" 
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           FontSize="12" 
                                                           Opacity="0.7" 
                                                           Margin="0,0,0,12" />

                                                <Border Grid.Row="2"
                                                        Background="White" 
                                                        CornerRadius="8" 
                                                        ClipToBounds="True"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,16">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" />
                                                    </Border.Effect>
                                                    <Grid Width="136" Height="136">
                                                        <Image x:Name="QrImage"
                                                               Margin="8"
                                                               Stretch="Uniform"
                                                               Source="{Binding QRCodeBitmapImage}" />
                                                        <Grid Visibility="{Binding IsQrCodeExpired, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                              Background="Transparent"
                                                              Cursor="Hand">
                                                            <Grid.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding RefreshQrCodeCommand}" />
                                                            </Grid.InputBindings>
                                                            <Border x:Name="OverlayBorder" CornerRadius="8">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="#99000000" />
                                                                </Border.Background>
                                                            </Border>
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <materialDesign:PackIcon x:Name="RefreshIcon"
                                                                                         Kind="Refresh"
                                                                                         Foreground="White"
                                                                                         HorizontalAlignment="Center"
                                                                                         Width="32" Height="32" Opacity="0.9"
                                                                                         RenderTransformOrigin="0.5,0.5">
                                                                    <materialDesign:PackIcon.RenderTransform>
                                                                        <TransformGroup>
                                                                            <ScaleTransform ScaleX="0.85" ScaleY="0.85" />
                                                                            <RotateTransform Angle="0" />
                                                                        </TransformGroup>
                                                                    </materialDesign:PackIcon.RenderTransform>
                                                                </materialDesign:PackIcon>
                                                                <TextBlock x:Name="RefreshText" 
                                                                           Text="点击刷新"
                                                                           Foreground="White"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Margin="0,4,0,0"
                                                                           Opacity="0.9"
                                                                           HorizontalAlignment="Center" />
                                                            </StackPanel>
                                                            <Grid.Triggers>
                                                                <EventTrigger RoutedEvent="MouseEnter">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <ColorAnimation Storyboard.TargetName="OverlayBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#B3000000" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetName="RefreshIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetName="RefreshIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetName="RefreshIcon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetName="RefreshText" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetName="RefreshIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(RotateTransform.Angle)" By="90" Duration="0:0:0.15" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                                <EventTrigger RoutedEvent="MouseLeave">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <ColorAnimation Storyboard.TargetName="OverlayBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#99000000" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetName="RefreshIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="0.85" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetName="RefreshIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="0.85" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetName="RefreshIcon" Storyboard.TargetProperty="Opacity" To="0.9" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetName="RefreshText" Storyboard.TargetProperty="Opacity" To="0.9" Duration="0:0:0.15" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Grid.Triggers>
                                                        </Grid>
                                                    </Grid>
                                                </Border>

                                                <Button x:Name="BackToMain"
                                                        Grid.Row="3"
                                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                                        materialDesign:ButtonAssist.CornerRadius="16"
                                                        HorizontalAlignment="Center"
                                                        Width="130"
                                                        Height="32"
                                                        ToolTip="返回主页面"
                                                        Click="BackToLoginPageButton_OnClick">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="ArrowLeft" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="返回" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </materialDesign:TransitionerSlide>

                                        <materialDesign:TransitionerSlide>
                                            <materialDesign:TransitionerSlide.BackwardWipe>
                                                <materialDesign:SlideWipe />
                                            </materialDesign:TransitionerSlide.BackwardWipe>
                                            <Grid Margin="24,0,24,0" VerticalAlignment="Center">
                                                <StackPanel>
                                                    <ComboBox x:Name="ProcessSelection"
                                                              materialDesign:HintAssist.Hint="{Binding ProcessSelectionHint}"
                                                              materialDesign:HintAssist.IsFloating="False"
                                                              ItemsSource="{Binding FFXIVProcesses}"
                                                              SelectedItem="{Binding SelectedProcess}"
                                                              Margin="0,0,0,20">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                                                    <materialDesign:PackIcon Kind="Forbid"
                                                                                             Height="16" Width="16"
                                                                                             Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                                                             Margin="0,0,8,0"
                                                                                             Visibility="{Binding HasInjected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>

                                                    <CheckBox x:Name="AutoInjectCheckBox"
                                                              Content="自动注入"
                                                              IsChecked="{Binding AutoInjectEnabled}"
                                                              Margin="0,0,0,12"
                                                              ToolTip="勾选后, 当检测到未注入 Dalamud 的游戏进程时, 自动执行注入" />

                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ElementName=AutoInjectCheckBox, Path=IsChecked}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="手动注入延迟"
                                                                   VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <TextBox Width="70"
                                                                     Text="{Binding ManualInjectDelayMs}"
                                                                     VerticalAlignment="Center" />
                                                            <TextBlock Text="ms"
                                                                       Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       Opacity="0.7" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="InjectButton"
                                                                Grid.Column="0"
                                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                materialDesign:ButtonAssist.CornerRadius="16"
                                                                Height="32"
                                                                Content="带回前台"
                                                                Click="InjectButton_Click"
                                                                IsEnabled="{Binding CanOperateOnSelectedProcess}" />
                                                        <Button x:Name="BringUp"
                                                                Grid.Column="2"
                                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                                materialDesign:ButtonAssist.CornerRadius="16"
                                                                Height="32"
                                                                Content="注  入"
                                                                Command="{Binding Path=InjectGameCommand}"
                                                                IsEnabled="{Binding CanOperateOnSelectedProcess}" />
                                                    </Grid>
                                                    
                                                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                            Command="{Binding Path=InjectModeSwitchCommand}"
                                                            Margin="0,0,0,0" Height="24" Padding="8,0"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{DynamicResource MaterialDesignBodyLight}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="ArrowLeft" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="返回账号登录" FontSize="11" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </materialDesign:TransitionerSlide>
                                    </materialDesign:Transitioner>

                                    <!-- Quick Links (Bottom) -->
                                    <Grid Grid.Row="2" Margin="16,0,16,12">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=LoginCardTransitioner, Path=SelectedIndex}" Value="1">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- 超域传送 -->
                                        <Button Grid.Row="0" Grid.Column="0" 
                                                Style="{StaticResource MaterialDesignOutlinedButton}" 
                                                Padding="0" 
                                                Height="32" 
                                                FontSize="11" 
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Click="DCTravelPageButton_OnClick">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Rocket" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="超域传送" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        
                                        <!-- 购卡充值 -->
                                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                                Padding="0" 
                                                Height="32" 
                                                FontSize="11" 
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Click="PayPageButton_OnClick">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ClockPlus" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="购卡充值" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- 商城中心 -->
                                        <Button Grid.Row="2" Grid.Column="0" 
                                                Style="{StaticResource MaterialDesignOutlinedButton}" 
                                                Padding="0" 
                                                Height="32"
                                                FontSize="11"
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Click="ShoppingPageButton_OnClick">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Cart" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="商城中心" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- 官方论坛 -->
                                        <Button Grid.Row="2" Grid.Column="2" 
                                                Style="{StaticResource MaterialDesignOutlinedButton}" 
                                                Padding="0" 
                                                Height="32" 
                                                FontSize="11" 
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Click="RisingStonePageButton_OnClick">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Forum" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="官方论坛" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>

                        <materialDesign:DialogHost
                            Identifier="MaintenanceQueueDialogHost"
                            x:Name="MaintenanceQueueDialogHost"
                            IsOpen="{Binding IsLoadingDialogOpen}">
                            <materialDesign:DialogHost.DialogContent>
                                <StackPanel Margin="16">
                                    <StackPanel Orientation="Vertical"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="LoadingMessageTextBlock"
                                                   Text="{Binding LoadingDialogMessage}" />
                                        <ProgressBar

                                            Style="{StaticResource MaterialDesignCircularProgressBar}"
                                            Value="0"
                                            IsIndeterminate="True" Height="30" Width="30" Margin="0 8 0 0" />
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:DialogHost.DialogContent>
                        </materialDesign:DialogHost>
                    </Grid>
                </Grid>
            </materialDesign:TransitionerSlide>
        </materialDesign:Transitioner>
    </Grid>
</Window>
