<Window
    x:Class="XIVLauncher.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:windows="clr-namespace:XIVLauncher.Windows"
    xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
    xmlns:site="clr-namespace:XIVLauncher.Common.Http.Site;assembly=XIVLauncher.Common"
    mc:Ignorable="d"
    Title="XIVLauncherCN (Soil)"
    Width="700"
    Height="420"
    UseLayoutRounding="True"
    ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
    Icon="pack://application:,,,/Resources/dalamud_icon.ico"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    Background="{DynamicResource MaterialDesignPaper}"
    TextElement.FontWeight="Bold" Closing="MainWindow_OnClosing"
    d:DataContext="{d:DesignInstance viewModel:MainWindowViewModel}">

    <Window.Resources>
        <system:Double x:Key="BannerCardWidth">399</system:Double>
        <system:Double x:Key="BannerCardHeight">213</system:Double>
        <Style x:Key="LoginActionContextMenuStyle"
               TargetType="{x:Type ContextMenu}"
               BasedOn="{StaticResource MaterialDesignContextMenu}" />
        <Style x:Key="LoginActionMenuItemStyle"
               TargetType="{x:Type MenuItem}"
               BasedOn="{StaticResource MaterialDesignMenuItem}" />
        <Style x:Key="LoginActionSeparatorStyle"
               TargetType="{x:Type Separator}"
               BasedOn="{StaticResource MaterialDesignSeparator}" />
    </Window.Resources>

    <Grid SnapsToDevicePixels="True" ClipToBounds="True">
        <materialDesign:Transitioner SelectedIndex="1">
            <materialDesign:Transitioner.CacheMode>
                <media:BitmapCache />
            </materialDesign:Transitioner.CacheMode>

            <materialDesign:TransitionerSlide>
                <materialDesign:TransitionerSlide.ForwardWipe>
                    <materialDesign:FadeWipe />
                </materialDesign:TransitionerSlide.ForwardWipe>
                <windows:SettingsControl x:Name="SettingsControl"
                                         DataContext="{Binding Settings}">
                    <windows:SettingsControl.CacheMode>
                        <media:BitmapCache />
                    </windows:SettingsControl.CacheMode>
                </windows:SettingsControl>
            </materialDesign:TransitionerSlide>

            <materialDesign:TransitionerSlide>
                <materialDesign:TransitionerSlide.BackwardWipe>
                    <materialDesign:FadeWipe />
                </materialDesign:TransitionerSlide.BackwardWipe>
                <Grid>
                    <Grid.CacheMode>
                        <media:BitmapCache />
                    </Grid.CacheMode>
                    <Grid Margin="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <materialDesign:Card
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0"
                                HorizontalAlignment="Left"
                                UniformCornerRadius="6"
                                Width="{DynamicResource BannerCardWidth}" Height="{DynamicResource BannerCardHeight}"
                                Cursor="Hand"
                                MouseUp="BannerCard_MouseUp">
                                <Grid>
                                    <Image x:Name="BannerImage"
                                           Stretch="UniformToFill"
                                           Source="pack://application:,,,/Resources/placeholder-news.png" />
                                </Grid>
                            </materialDesign:Card>

                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,10,10"
                                    Background="Transparent">
                                <ItemsControl x:Name="BannerDot" d:ItemsSource="{d:SampleData ItemCount=5}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModel:BannerDotInfo}">
                                            <RadioButton GroupName="banner"
                                                         IsChecked="{Binding Active, Mode=OneWay}"
                                                         Checked="BannerDot_OnChecked"
                                                         MouseEnter="RadioButton_MouseEnter"
                                                         MouseLeave="RadioButton_MouseLeave"
                                                         Margin="3,0"
                                                         Cursor="Hand"
                                                         Style="{StaticResource {x:Type ToggleButton}}">
                                                <RadioButton.Template>
                                                    <ControlTemplate TargetType="RadioButton">
                                                        <Border x:Name="DotBorder"
                                                                Width="8" Height="8"
                                                                CornerRadius="4"
                                                                Background="#88FFFFFF" />
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="DotBorder" Property="Background" Value="#FFFFFFFF" />
                                                                <Setter TargetName="DotBorder" Property="Width" Value="18" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="DotBorder" Property="Background" Value="#CCFFFFFF" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </RadioButton.Template>
                                            </RadioButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <materialDesign:Card
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0 12 0 4"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Left" 
                                Width="{DynamicResource BannerCardWidth}">
                                <ListBox x:Name="NewsListView"
                                         MouseUp="NewsListView_OnMouseUp"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="4,2"
                                         ScrollViewer.CanContentScroll="True"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         HorizontalContentAlignment="Stretch">
                                    <ListBox.Template>
                                        <ControlTemplate TargetType="ListBox">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                                <ScrollViewer
                                                    Focusable="False"
                                                    CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                                    HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                    VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                                    <ItemsPresenter />
                                                </ScrollViewer>
                                            </Border>
                                        </ControlTemplate>
                                    </ListBox.Template>
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem"
                                               BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="MinHeight" Value="32" />
                                            <Setter Property="Padding" Value="6,4,6,4" />
                                            <Setter Property="Margin" Value="0,1" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:Name="SingleLineDataTemplate"
                                                      DataType="site:News">
                                            <Grid Background="Transparent">
                                                <Grid.ToolTip>
                                                    <ToolTip Placement="Right">
                                                        <TextBlock>
                                                            <Run Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" 
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                                                 FontWeight="SemiBold"/>
                                                            <Run Text="  " />
                                                            <Run Text="{Binding Title}" />
                                                        </TextBlock>
                                                    </ToolTip>
                                                </Grid.ToolTip>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <Border Grid.Column="0" 
                                                        Background="{DynamicResource PrimaryHueMidBrush}" 
                                                        Opacity="0.12"
                                                        CornerRadius="4" 
                                                        VerticalAlignment="Center">
                                                </Border>
                                                <TextBlock Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Padding="0 2 4 2"
                                                           Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" />

                                                <TextBlock Grid.Column="1"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           LineHeight="16"
                                                           Text="{Binding Title}"
                                                           TextWrapping="Wrap" />
                                                           
                                                <materialDesign:PackIcon Grid.Column="2" 
                                                                         Kind="ChevronRight" 
                                                                         VerticalAlignment="Center" 
                                                                         Width="14" Height="14" 
                                                                         Opacity="0.4" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </materialDesign:Card>



                            <materialDesign:Card
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Width="260"
                                Margin="8 0 0 4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                SnapsToDevicePixels="True"
                                ClipToBounds="True"
                                KeyDown="Card_KeyDown">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,8,8,0">
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                ToolTip="{Binding Path=ModeSwitchTitle}"
                                                Command="{Binding Path=InjectModeSwitchCommand}"
                                                Width="32" Height="32" Padding="4"
                                                Focusable="False" Cursor="Hand">
                                            <materialDesign:PackIcon Kind="{Binding ModeSwitchIcon}" Width="20" Height="20" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                ToolTip="启动器设置"
                                                Command="{x:Static materialDesign:Transitioner.MovePreviousCommand}"
                                                Width="32" Height="32" Padding="4"
                                                Focusable="False" Cursor="Hand">
                                            <materialDesign:PackIcon Kind="Gear" Width="20" Height="20" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        </Button>
                                    </StackPanel>

                                    <materialDesign:Transitioner Grid.Row="1" VerticalAlignment="Center" SelectedIndex="{Binding LoginCardTransitionerIndex}">
                                <materialDesign:TransitionerSlide>
                                    <materialDesign:TransitionerSlide.ForwardWipe>
                                        <materialDesign:FadeWipe />
                                    </materialDesign:TransitionerSlide.ForwardWipe>

                                        <DockPanel
                                            Margin="30,18,30,18">
                                            <TextBlock Text="正在登录…"
                                                       DockPanel.Dock="Top"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Top"
                                                       TextAlignment="Center"
                                                       Margin="0,20,0,0" />
                                            <ProgressBar
                                                x:Name="ProgressBar"
                                                DockPanel.Dock="Top"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                Value="0"
                                                IsIndeterminate="True" Height="30" Width="30" Margin="0 18 0 0" />
                                            <TextBlock Text="{Binding LoginMessage}"
                                                       DockPanel.Dock="Top"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Top"
                                                       TextAlignment="Center"
                                                       Margin="0,18,0,0" />
                                            <Button
                                                Content="取消登录"
                                                Command="{Binding Path=LoginCancelCommand}"
                                                Margin="0,0,7,0" Width="142"
                                                HorizontalAlignment="Center"
                                                ToolTip="取消登录" />

                                        </DockPanel>

                                    </materialDesign:TransitionerSlide>

                                    <materialDesign:TransitionerSlide>
                                        <materialDesign:TransitionerSlide.BackwardWipe>
                                            <materialDesign:FadeWipe />
                                        </materialDesign:TransitionerSlide.BackwardWipe>

                                        <DockPanel Height="204" Margin="20,-20,20,0">
                                            <ComboBox
                                                DockPanel.Dock="Top"
                                                x:Name="LoginTypeSelection"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,10,0,0"
                                                Height="24"
                                                VerticalAlignment="Top"
                                                SelectedItem="{Binding Path=LoginTypeOption}"
                                                SelectedValuePath="LoginType"
                                                DisplayMemberPath="DisplayName"
                                                SelectionChanged="LoginTypeSelection_OnSelectionChanged"
                                                materialDesign:HintAssist.Hint="选择登录方式" />
                                            <ListBox
                                                x:Name="ServerSelection"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Top"
                                                materialDesign:HintAssist.Hint="选择服务器"
                                                DockPanel.Dock="Top"
                                                ItemsSource="{Binding Path=LoginAreas}"
                                                SelectedIndex="{Binding Path=AreaIndex, Mode=OneWayToSource}"
                                                SelectedItem="{Binding Path=Area}"
                                                SelectedValuePath="AreaID">
                                                <!--  完全移除ScrollViewer  -->
                                                <ListBox.Template>
                                                    <ControlTemplate TargetType="ListBox">
                                                        <Border>
                                                            <ItemsPresenter />
                                                        </Border>
                                                    </ControlTemplate>
                                                </ListBox.Template>
                                                <ListBox.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"
                                                                    ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                                                        <!--  横向排列并自动换行  -->
                                                    </ItemsPanelTemplate>
                                                </ListBox.ItemsPanel>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border Background="{TemplateBinding Background}">
                                                                        <Grid>
                                                                            <!--  内容区域  -->
                                                                            <ContentPresenter />
                                                                            <!--  选中状态的亮线  -->
                                                                            <Border
                                                                                Name="SelectionIndicator"
                                                                                Height="2"
                                                                                VerticalAlignment="Bottom"
                                                                                Background="{DynamicResource PrimaryHueMidBrush}"
                                                                                Opacity="0" />
                                                                        </Grid>
                                                                        <VisualStateManager.VisualStateGroups>
                                                                            <VisualStateGroup Name="SelectionStates">
                                                                                <VisualState Name="Unselected">
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation
                                                                                            Storyboard.TargetName="SelectionIndicator"
                                                                                            Storyboard.TargetProperty="Opacity"
                                                                                            To="0"
                                                                                            Duration="0:0:0.2" />
                                                                                    </Storyboard>
                                                                                </VisualState>
                                                                                <VisualState Name="Selected">
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation
                                                                                            Storyboard.TargetName="SelectionIndicator"
                                                                                            Storyboard.TargetProperty="Opacity"
                                                                                            To="1"
                                                                                            Duration="0:0:0.2" />
                                                                                    </Storyboard>
                                                                                </VisualState>
                                                                            </VisualStateGroup>
                                                                        </VisualStateManager.VisualStateGroups>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <!--  自定义项模板  -->
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock
                                                            Margin="5.8"
                                                            VerticalAlignment="Center"
                                                            FontSize="14"
                                                            Text="{Binding AreaName}" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <TextBox
                                                DockPanel.Dock="Top"
                                                x:Name="LoginUsername"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,5,0,0"
                                                Height="24"
                                                TextWrapping="Wrap"
                                                VerticalAlignment="Top"
                                                materialDesign:HintAssist.Hint="盛趣账号"
                                                TextChanged="LoginUsername_OnTextChanged"
                                                Text="{Binding Username}" Cursor="IBeam" />
                                            <PasswordBox
                                                IsEnabled="True"
                                                DockPanel.Dock="Top"
                                                x:Name="LoginPassword"
                                                HorizontalAlignment="Stretch"
                                                Height="24"
                                                Margin="0,8,0,0"
                                                VerticalAlignment="Top"
                                                PasswordChanged="LoginPassword_OnPasswordChanged"
                                                materialDesign:HintAssist.Hint="密码"
                                                Cursor="IBeam" />

                                            <CheckBox
                                                Visibility="Visible"
                                                DockPanel.Dock="Top"
                                                Content="快速登录"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,8,0,0"
                                                VerticalAlignment="Top"
                                                x:Name="FastLoginCheckBox"
                                                IsChecked="{Binding IsFastLogin}" />

                                            <CheckBox
                                                Visibility="Hidden"
                                                DockPanel.Dock="Top"
                                                Content="读取登录信息"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,8,0,0"
                                                VerticalAlignment="Top"
                                                x:Name="ReadWeGameInfoCheckBox"
                                                ToolTip="从WeGame版FFXIV中读取登录信息"
                                                IsChecked="{Binding IsReadWegameInfo}" />

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,0,10" DockPanel.Dock="Bottom">
                                                <Button
                                                    x:Name="LoginButton"
                                                    Content="登录"
                                                    Command="{Binding Path=StartLoginCommand}"
                                                    Margin="0,0,0,0" Width="84">

                                                    <Button.ContextMenu>
                                                        <ContextMenu Language="zh-CN"
                                                                     Style="{StaticResource LoginActionContextMenuStyle}">
                                                            <ContextMenu.Resources>
                                                                <Style TargetType="{x:Type MenuItem}"
                                                                       BasedOn="{StaticResource LoginActionMenuItemStyle}" />
                                                                <Style TargetType="{x:Type Separator}"
                                                                       BasedOn="{StaticResource LoginActionSeparatorStyle}" />
                                                            </ContextMenu.Resources>
                                                            <MenuItem Header="修复"
                                                                      Command="{Binding Path=LoginRepairCommand}" />
                                                            <MenuItem Header="更新"
                                                                      Command="{Binding Path=LoginNoStartCommand}" />
                                                            <Separator />
                                                            <MenuItem Header="其他启动方式">
                                                                <MenuItem Header="无 Dalamud"
                                                                          Command="{Binding Path=LoginNoDalamudCommand}" />
                                                                <MenuItem Header="禁用插件"
                                                                          Command="{Binding Path=LoginNoPluginsCommand}" />
                                                                <MenuItem Header="禁用第三方插件"
                                                                          Command="{Binding Path=LoginNoThirdCommand}" />
                                                                <Separator />
                                                                <MenuItem Header="调试用假启动"
                                                                          Command="{Binding Path=FakeStartCommand}" />
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>

                                                </Button>

                                                <Button HorizontalAlignment="Left"
                                                        Visibility="Visible"
                                                        x:Name="AccountSwitcherButton" Margin="7 0 0 0"
                                                        ToolTip="账户管理器"
                                                        Click="AccountSwitcherButton_OnClick">
                                                    <StackPanel Orientation="Horizontal" Margin="0">
                                                        <materialDesign:PackIcon
                                                            Kind="AccountGroup" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </DockPanel>

                                    </materialDesign:TransitionerSlide>

                                    <materialDesign:TransitionerSlide>
                                        <materialDesign:TransitionerSlide.BackwardWipe>
                                            <materialDesign:FadeWipe />
                                        </materialDesign:TransitionerSlide.BackwardWipe>

                                        <DockPanel
                                            Margin="30,18,30,18">
                                            <Image
                                                Width="130" Height="130"
                                                DockPanel.Dock="Top"
                                                x:Name="QrImage"
                                                Stretch="Uniform"
                                                Source="{Binding QRCodeBitmapImage}" />

                                            <Button HorizontalAlignment="Center"
                                                    Visibility="Visible"
                                                    x:Name="BackToMain" Margin="0 0 0 0"
                                                    ToolTip="返回登录页面"
                                                    Click="BackToLoginPageButton_OnClick">
                                                <StackPanel Orientation="Horizontal" Margin="0">
                                                    <materialDesign:PackIcon
                                                        Kind="RedoVariant" RenderTransformOrigin="0.5,0.5" Cursor="">
                                                        <materialDesign:PackIcon.RenderTransform>
                                                            <TransformGroup>
                                                                <ScaleTransform />
                                                                <SkewTransform />
                                                                <RotateTransform Angle="180" />
                                                                <TranslateTransform />
                                                            </TransformGroup>
                                                        </materialDesign:PackIcon.RenderTransform>
                                                    </materialDesign:PackIcon>
                                                </StackPanel>
                                            </Button>
                                        </DockPanel>

                                    </materialDesign:TransitionerSlide>

                                    <materialDesign:TransitionerSlide>
                                        <materialDesign:TransitionerSlide.BackwardWipe>
                                            <materialDesign:SlideWipe />
                                        </materialDesign:TransitionerSlide.BackwardWipe>
                                        <DockPanel
                                            Margin="30,18,30,18">
                                            <ComboBox
                                                DockPanel.Dock="Top"
                                                x:Name="ProcessSelection"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,10,0,0"
                                                Height="24"
                                                VerticalAlignment="Top"
                                                ItemsSource="{Binding FFXIVProcesses}"
                                                SelectedItem="{Binding SelectedProcess}"
                                                materialDesign:HintAssist.Hint="{Binding ProcessSelectionHint}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon
                                                                Kind="Forbid"
                                                                Height="16" Width="16"
                                                                Visibility="{Binding HasInjected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            <TextBlock Text="{Binding DisplayName}" Margin="0,0,5,0" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,0,10" DockPanel.Dock="Bottom">
                                                <Button
                                                    x:Name="InjectButton"
                                                    Content="带回前台"
                                                    Click="InjectButton_Click"
                                                    IsEnabled="{Binding CanOperateOnSelectedProcess}"
                                                    Margin="0,0,10,0" Width="90" />
                                                <Button
                                                    x:Name="BringUp"
                                                    Content="注入"
                                                    Command="{Binding Path=InjectGameCommand}"
                                                    IsEnabled="{Binding CanOperateOnSelectedProcess}"
                                                    Margin="0,0,0,0" Width="90" />
                                            </StackPanel>
                                        </DockPanel>

                                    </materialDesign:TransitionerSlide>
                                </materialDesign:Transitioner>

                                    <!-- Quick Links (Bottom) -->
                                    <Grid Grid.Row="2" Margin="16,0,16,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- 超域传送 -->
                                        <Button Grid.Row="0" Grid.Column="0" 
                                                Style="{StaticResource MaterialDesignOutlinedButton}" 
                                                Padding="4" 
                                                Height="36" 
                                                FontSize="12" 
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Click="DCTravelPageButton_OnClick">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Rocket" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="超域传送" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        
                                        <!-- 购卡充值 -->
                                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                                Padding="4" 
                                                Height="36" 
                                                FontSize="12" 
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Click="PayPageButton_OnClick">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ClockPlus" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="购卡充值" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- 商城中心 -->
                                        <Button Grid.Row="2" Grid.Column="0" 
                                                Style="{StaticResource MaterialDesignOutlinedButton}" 
                                                Padding="4" 
                                                Height="36"
                                                FontSize="12"
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Click="ShoppingPageButton_OnClick">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Cart" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="商城中心" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- 官方论坛 -->
                                        <Button Grid.Row="2" Grid.Column="2" 
                                                Style="{StaticResource MaterialDesignOutlinedButton}" 
                                                Padding="4" 
                                                Height="36" 
                                                FontSize="12" 
                                                Foreground="{DynamicResource MaterialDesignBody}"
                                                Click="RisingStonePageButton_OnClick">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Forum" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="官方论坛" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>

                        <materialDesign:DialogHost
                            Identifier="MaintenanceQueueDialogHost"
                            x:Name="MaintenanceQueueDialogHost"
                            IsOpen="{Binding IsLoadingDialogOpen}">
                            <materialDesign:DialogHost.DialogContent>
                                <StackPanel Margin="16">
                                    <StackPanel Orientation="Vertical"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="LoadingMessageTextBlock"
                                                   Text="{Binding LoadingDialogMessage}" />
                                        <ProgressBar

                                            Style="{StaticResource MaterialDesignCircularProgressBar}"
                                            Value="0"
                                            IsIndeterminate="True" Height="30" Width="30" Margin="0 8 0 0" />
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:DialogHost.DialogContent>
                        </materialDesign:DialogHost>
                    </Grid>
                </Grid>
            </materialDesign:TransitionerSlide>
        </materialDesign:Transitioner>
    </Grid>
</Window>
