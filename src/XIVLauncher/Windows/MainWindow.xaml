<Window
    x:Class="XIVLauncher.Windows.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mahIcon="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:data="clr-namespace:System.Windows.Data;assembly=PresentationFramework"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
    xmlns:site="clr-namespace:XIVLauncher.Common.Http.Site;assembly=XIVLauncher.Common"
    xmlns:constant="clr-namespace:XIVLauncher.Common.Constant;assembly=XIVLauncher.Common"
    xmlns:models="clr-namespace:XIVLauncher.Windows.ViewModel.MainWindow.Models"
    xmlns:transitions="clr-namespace:XIVLauncher.Xaml.Transitions"
    xmlns:mainWindow="clr-namespace:XIVLauncher.Windows.ViewModel.MainWindow"
    mc:Ignorable="d"
    Title="XIVLauncherCN (Soil)"
    Width="780"
    Height="540"
    ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
    Icon="pack://application:,,,/Resources/dalamud_icon.ico"
    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
    Background="{DynamicResource MaterialDesign.Brush.Background}"
    Closing="MainWindow_OnClosing"
    d:DataContext="{d:DesignInstance viewModel:MainWindowViewModel}">

    <Window.Resources>
        <system:Double x:Key="BannerCardWidth">450</system:Double>
        <system:Double x:Key="BannerCardHeight">250</system:Double>
        <Style x:Key="LoginActionContextMenuStyle"
               TargetType="{x:Type ContextMenu}"
               BasedOn="{StaticResource MaterialDesignContextMenu}" />
        <Style x:Key="LoginActionMenuItemStyle"
               TargetType="{x:Type MenuItem}"
               BasedOn="{StaticResource MaterialDesignMenuItem}" />
        <Style x:Key="LoginActionSeparatorStyle"
               TargetType="{x:Type Separator}"
               BasedOn="{StaticResource MaterialDesignSeparator}" />
        <Style x:Key="HeaderUtilityButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource MaterialDesignIconForegroundButton}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.86" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SocialSiteButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        </Style>
        <Style x:Key="QuickLinkButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        </Style>
        <Style x:Key="PrimaryQuickLinkButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
        </Style>
        <Style x:Key="DalamudStatusButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
        </Style>
        <Style x:Key="AccountFieldCopyButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource MaterialDesignIconForegroundButton}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.65" />
            <Setter Property="Visibility" Value="Hidden" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}"
                             Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DashboardInfoCardStyle"
               TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.BackgroundDark}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <materialDesign:Card
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0"
                    HorizontalAlignment="Left"
                    UniformCornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Width="{DynamicResource BannerCardWidth}" Height="{DynamicResource BannerCardHeight}"
                    Cursor="Hand"
                    MouseUp="BannerCard_MouseUp">
                    <Grid>
                        <Image x:Name="BannerImage"
                               Stretch="Fill"
                               Source="pack://application:,,,/Resources/placeholder-news.png" />
                    </Grid>
                </materialDesign:Card>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,4,4"
                        Background="Transparent">
                    <ItemsControl x:Name="BannerDot" d:ItemsSource="{d:SampleData ItemCount=5}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:BannerDotInfo}">
                                <RadioButton GroupName="banner"
                                             IsChecked="{Binding Active, Mode=OneWay}"
                                             Checked="BannerDot_OnChecked"
                                             MouseEnter="RadioButton_MouseEnter"
                                             MouseLeave="RadioButton_MouseLeave"
                                             Margin="0"
                                             Cursor="Hand"
                                             Style="{StaticResource {x:Type ToggleButton}}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="DotBorder"
                                                    Width="8" Height="8"
                                                    CornerRadius="4"
                                                    Background="#88FFFFFF" />
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="DotBorder" Property="Background"
                                                            Value="#FFFFFFFF" />
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="DotBorder"
                                                                    Storyboard.TargetProperty="Width"
                                                                    To="24" Duration="0:0:0.3">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="DotBorder"
                                                                    Storyboard.TargetProperty="Width"
                                                                    To="8" Duration="0:0:0.3">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                        <Condition Property="IsChecked" Value="False" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="DotBorder" Property="Background"
                                                            Value="#CCFFFFFF" />
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                                 </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <materialDesign:Card
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0 12 0 4"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Left"
                    UniformCornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp2"
                    Width="{DynamicResource BannerCardWidth}">
                    <ListBox x:Name="NewsListView"
                             MouseUp="NewsListView_OnMouseUp"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4,2"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.Template>
                            <ControlTemplate TargetType="ListBox">
                                <Border
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                    <ScrollViewer
                                        Focusable="False"
                                        CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                        HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                        VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </ListBox.Template>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem"
                                   BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="MinHeight" Value="32" />
                                <Setter Property="Padding" Value="6,4,6,4" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:Name="SingleLineDataTemplate"
                                          DataType="site:News">
                                <Grid Background="Transparent">
                                    <Grid.ToolTip>
                                        <ToolTip Placement="Right">
                                            <TextBlock>
                                                <Run Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}"
                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                     FontWeight="SemiBold" />
                                                <Run Text="  " />
                                                <Run Text="{Binding Title}" />
                                            </TextBlock>
                                        </ToolTip>
                                    </Grid.ToolTip>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                            Opacity="0.12"
                                            CornerRadius="4"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Padding="0 2 4 2"
                                               Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" />

                                    <TextBlock Grid.Column="1"
                                               Margin="4,0,4,0"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               LineHeight="16"
                                               Text="{Binding Title}"
                                               TextWrapping="Wrap" />

                                    <materialDesign:PackIcon Grid.Column="2"
                                                             Kind="ChevronRight"
                                                             VerticalAlignment="Center"
                                                             Width="14" Height="14"
                                                             Opacity="0.4" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </materialDesign:Card>


                <materialDesign:Card
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    Width="280"
                    Margin="8 0 0 4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    UniformCornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp4"
                    KeyDown="Card_KeyDown">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="8,8,8,0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding ElementName=LoginCardTransitioner, Path=SelectedIndex}"
                                            Value="1">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding ElementName=LoginCardTransitioner, Path=SelectedIndex}"
                                            Value="4">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <Button Style="{StaticResource HeaderUtilityButtonStyle}"
                                        ToolTip="修复"
                                        Command="{Binding LoginPage.LoginRepairCommand}">
                                    <materialDesign:PackIcon Kind="Wrench"
                                                             Width="20"
                                                             Height="20"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                </Button>

                                <Button Style="{StaticResource HeaderUtilityButtonStyle}"
                                        ToolTip="完整性检查"
                                        Command="{Binding LoginPage.RunIntegrityCheckCommand}">
                                    <materialDesign:PackIcon Kind="ShieldCheck"
                                                             Width="20"
                                                             Height="20"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                </Button>

                                <Button Style="{StaticResource HeaderUtilityButtonStyle}"
                                        ToolTip="更新"
                                        Command="{Binding LoginPage.LoginNoStartCommand}">
                                    <materialDesign:PackIcon Kind="Update"
                                                             Width="20"
                                                             Height="20"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                </Button>

                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <Button
                                    Style="{StaticResource HeaderUtilityButtonStyle}"
                                    ToolTip="手动注入"
                                    Command="{Binding LoginPage.InjectModeSwitchCommand}"
                                    Visibility="{Binding Settings.EnableHooks, Converter={StaticResource BoolToVis}}">
                                    <materialDesign:PackIcon Kind="Injection" Width="20" Height="20"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                </Button>

                                <Button
                                    Style="{StaticResource HeaderUtilityButtonStyle}"
                                    ToolTip="软件设置"
                                    Click="SettingsButton_OnClick">
                                    <materialDesign:PackIcon Kind="Gear" Width="20" Height="20"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                </Button>

                            </StackPanel>


                        </Grid>

                        <materialDesign:Transitioner x:Name="LoginCardTransitioner" Grid.Row="1"
                                                     VerticalAlignment="Stretch"
                                                     SelectedIndex="{Binding LoginCardTransitionerIndex}">
                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.ForwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.ForwardWipe>

                                <Grid Margin="24,0,24,0" VerticalAlignment="Center">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,20" Width="80" Height="80"
                                              HorizontalAlignment="Center">
                                            <!-- Pulsing circle -->
                                            <Ellipse Fill="{DynamicResource MaterialDesign.Brush.Primary}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" Width="48" Height="48">
                                                <Ellipse.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="Width"
                                                                    From="48" To="80" Duration="0:0:1.5"
                                                                    AutoReverse="True">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <SineEase EasingMode="EaseInOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="Height"
                                                                    From="48" To="80" Duration="0:0:1.5"
                                                                    AutoReverse="True">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <SineEase EasingMode="EaseInOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    From="0.25" To="0.05"
                                                                    Duration="0:0:1.5" AutoReverse="True">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <SineEase EasingMode="EaseInOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Ellipse.Triggers>
                                            </Ellipse>

                                            <ProgressBar x:Name="ProgressBar"
                                                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                         Value="0"
                                                         IsIndeterminate="{Binding IsLoggingIn}"
                                                         Height="52" Width="52"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />

                                            <materialDesign:PackIcon Kind="Login"
                                                                     Width="24" Height="24"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                                <materialDesign:PackIcon.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    From="0.5" To="1.0" Duration="0:0:1.5"
                                                                    AutoReverse="True">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <SineEase EasingMode="EaseInOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </materialDesign:PackIcon.Triggers>
                                            </materialDesign:PackIcon>
                                        </Grid>

                                        <TextBlock Text="正在登录"
                                                   HorizontalAlignment="Center"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8" />

                                        <TextBlock Text="{Binding LoginPage.LoginMessage}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   FontSize="13"
                                                   Margin="0,0,0,24">
                                            <TextBlock.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="Opacity"
                                                                From="0.4" To="0.9" Duration="0:0:1.5"
                                                                AutoReverse="True">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <SineEase EasingMode="EaseInOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </TextBlock.Triggers>
                                        </TextBlock>

                                        <Button Content="取消"
                                                Command="{Binding LoginPage.LoginCancelCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="16"
                                                HorizontalAlignment="Center"
                                                Width="120"
                                                ToolTip="取消登录" />
                                    </StackPanel>
                                </Grid>
                            </materialDesign:TransitionerSlide>

                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.BackwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.BackwardWipe>

                                <Grid Margin="20,0,20,0" VerticalAlignment="Center">
                                    <StackPanel>
                                        <!--  Login Type & Area  -->
                                        <ComboBox x:Name="LoginTypeSelection"
                                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                  materialDesign:HintAssist.Hint="登录方式"
                                                  SelectionChanged="LoginTypeSelection_OnSelectionChanged"
                                                  SelectedItem="{Binding LoginPage.LoginTypeOption}"
                                                  SelectedValuePath="LoginType"
                                                  Tag="SelectionBox"
                                                  Margin="0,0,0,8">
                                            <ComboBox.Resources>
                                                <CollectionViewSource x:Key="LoginTypeOptionsView"
                                                                      Source="{Binding LoginPage.LoginTypeOptions}">
                                                    <CollectionViewSource.GroupDescriptions>
                                                        <PropertyGroupDescription
                                                            PropertyName="GroupDisplay" />
                                                    </CollectionViewSource.GroupDescriptions>
                                                </CollectionViewSource>
                                            </ComboBox.Resources>
                                            <ComboBox.ItemsSource>
                                                <Binding Source="{StaticResource LoginTypeOptionsView}" />
                                            </ComboBox.ItemsSource>
                                            <ComboBox.GroupStyle>
                                                <GroupStyle>
                                                    <GroupStyle.HeaderTemplate>
                                                        <DataTemplate
                                                            DataType="{x:Type data:CollectionViewGroup}">
                                                            <Grid Margin="0,6,0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="11"
                                                                           Opacity="0.5"
                                                                           Margin="8,0,8,0"
                                                                           VerticalAlignment="Center" />
                                                                <Separator Grid.Column="1"
                                                                           Margin="0,0,8,0"
                                                                           Background="{DynamicResource MaterialDesign.Brush.Card.Border}"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </GroupStyle.HeaderTemplate>
                                                </GroupStyle>
                                            </ComboBox.GroupStyle>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal">
                                                            <Ellipse Width="5" Height="5"
                                                                     Fill="{DynamicResource MaterialDesign.Brush.Primary}"
                                                                     VerticalAlignment="Center">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Visibility"
                                                                                Value="Collapsed" />
                                                                        <Setter Property="Margin"
                                                                                Value="0,0,0,0" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger
                                                                                Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                                                                Value="{x:Null}">
                                                                                <Setter
                                                                                    Property="Visibility"
                                                                                    Value="Visible" />
                                                                                <Setter Property="Margin"
                                                                                    Value="0,0,8,0" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>

                                                        <Grid Grid.Column="1" Margin="8,0,0,0"
                                                              VerticalAlignment="Center">
                                                            <Grid.Style>
                                                                <Style TargetType="Grid">
                                                                    <Setter Property="Visibility"
                                                                            Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger
                                                                            Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                                                            Value="SelectionBox">
                                                                            <Setter Property="Visibility"
                                                                                    Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Style>

                                                            <Border
                                                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                                Opacity="0.12"
                                                                CornerRadius="4" />
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Padding="4,2"
                                                                       Text="{Binding GroupDisplay}" />
                                                        </Grid>
                                                    </Grid>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <!--  Credentials  -->
                                        <TextBox x:Name="LoginUsername"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                 materialDesign:HintAssist.Hint="{Binding LoginPage.UsernameHint}"
                                                 TextChanged="LoginUsername_OnTextChanged"
                                                 ToolTipService.ShowOnDisabled="True"
                                                 TextWrapping="NoWrap"
                                                 Text="{Binding LoginPage.Username, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{Binding LoginPage.UsernameToolTip}"
                                                 IsEnabled="{Binding LoginPage.IsUsernameEnabled}"
                                                 Visibility="{Binding LoginPage.IsUsernameVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 Cursor="IBeam"
                                                 Margin="0,0,0,8" />

                                        <PasswordBox x:Name="LoginPassword"
                                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                     materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                     materialDesign:HintAssist.Hint="{Binding LoginPage.PasswordHint}"
                                                     PasswordChanged="LoginPassword_OnPasswordChanged"
                                                     Visibility="{Binding LoginPage.IsPasswordVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                     Cursor="IBeam"
                                                     Margin="0,0,0,8" />

                                        <!--  Options  -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10"
                                                    HorizontalAlignment="Center">
                                            <CheckBox x:Name="FastLoginCheckBox"
                                                      Content="{Binding LoginPage.FastLoginText}"
                                                      IsChecked="{Binding LoginPage.IsFastLogin}"
                                                      IsEnabled="{Binding LoginPage.IsFastLoginEnabled}"
                                                      Visibility="{Binding LoginPage.IsFastLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                      ToolTip="勾选后, 在登录时会自动保存账号信息, 以供下次快速登录"
                                                      Margin="0,0,16,0" />
                                            <CheckBox x:Name="ReadWeGameInfoCheckBox"
                                                      Content="{Binding LoginPage.ReadWeGameInfoText}"
                                                      Visibility="{Binding LoginPage.IsReadWegameInfoVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                      ToolTip="{Binding LoginPage.ReadWeGameInfoToolTip}"
                                                      IsChecked="{Binding LoginPage.IsReadWegameInfo}" />
                                        </StackPanel>

                                        <!--  Actions  -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Button x:Name="LoginButton"
                                                    Grid.Column="0"
                                                    Content="登录"
                                                    Command="{Binding LoginPage.StartLoginCommand}"
                                                    IsEnabled="{Binding LoginPage.CanStartLogin}"
                                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="18"
                                                    materialDesign:ElevationAssist.Elevation="Dp2"
                                                    Height="32"
                                                    FontSize="14"
                                                    FontWeight="Bold">
                                                <Button.ContextMenu>
                                                    <ContextMenu Language="zh-CN"
                                                                 Style="{StaticResource LoginActionContextMenuStyle}">
                                                        <ContextMenu.Resources>
                                                            <Style TargetType="{x:Type MenuItem}"
                                                                   BasedOn="{StaticResource LoginActionMenuItemStyle}" />
                                                            <Style TargetType="{x:Type Separator}"
                                                                   BasedOn="{StaticResource LoginActionSeparatorStyle}" />
                                                        </ContextMenu.Resources>
                                                        <MenuItem Header="无 Dalamud"
                                                                  Command="{Binding LoginPage.LoginNoDalamudCommand}" />
                                                        <MenuItem Header="禁用插件"
                                                                  Command="{Binding LoginPage.LoginNoPluginsCommand}" />
                                                        <MenuItem Header="禁用第三方插件"
                                                                  Command="{Binding LoginPage.LoginNoThirdCommand}" />
                                                        <Separator Margin="0 8" />
                                                        <MenuItem Header="调试用假启动"
                                                                  Command="{Binding LoginPage.FakeStartCommand}" />
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>

                                            <Button x:Name="AccountSwitcherButton"
                                                    Grid.Column="2"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="18"
                                                    Width="32" Height="32" Padding="0"
                                                    ToolTip="账户管理器"
                                                    Command="{Binding AccountSwitcherButtonCommand}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource Self}}">
                                                <materialDesign:PackIcon Kind="AccountGroup" Width="18"
                                                                         Height="18" />
                                            </Button>

                                            <Border x:Name="AccountSwitcherPopupPlaceholder" Visibility="Collapsed" />
                                        </Grid>

                                    </StackPanel>
                                </Grid>
                            </materialDesign:TransitionerSlide>

                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.BackwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.BackwardWipe>

                                <Grid Margin="24,12,24,8" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="扫码登录"
                                               HorizontalAlignment="Center"
                                               FontSize="16"
                                               Margin="0,0,0,8" />
                                    <TextBlock Grid.Row="1"
                                               Text="请打开手机叨鱼应用程序扫码登录"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               FontSize="12"
                                               Opacity="0.7"
                                               Margin="0,0,0,12" />

                                    <Border Grid.Row="2"
                                            Background="White"
                                            CornerRadius="8"
                                            ClipToBounds="True"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,16">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"
                                                              RenderingBias="Performance" />
                                        </Border.Effect>
                                        <Grid Width="136" Height="136">
                                            <Image x:Name="QrImage"
                                                   Margin="8"
                                                   Stretch="Uniform"
                                                   Source="{Binding LoginPage.QRCodeBitmapImage}" />
                                            <Grid
                                                Visibility="{Binding LoginPage.IsQrCodeExpired, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Background="Transparent"
                                                Cursor="Hand">
                                                <Grid.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding LoginPage.RefreshQrCodeCommand}" />
                                                </Grid.InputBindings>
                                                <Border x:Name="OverlayBorder" CornerRadius="8">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#99000000" />
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <materialDesign:PackIcon x:Name="RefreshIcon"
                                                                             Kind="Refresh"
                                                                             Foreground="White"
                                                                             HorizontalAlignment="Center"
                                                                             Width="32" Height="32" Opacity="0.9"
                                                                             RenderTransformOrigin="0.5,0.5">
                                                        <materialDesign:PackIcon.RenderTransform>
                                                            <TransformGroup>
                                                                <ScaleTransform ScaleX="0.85" ScaleY="0.85" />
                                                                <RotateTransform Angle="0" />
                                                            </TransformGroup>
                                                        </materialDesign:PackIcon.RenderTransform>
                                                    </materialDesign:PackIcon>
                                                    <TextBlock x:Name="RefreshText"
                                                               Text="点击刷新"
                                                               Foreground="White"
                                                               FontSize="12"
                                                               Margin="0,4,0,0"
                                                               Opacity="0.9"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                                <Grid.Triggers>
                                                    <EventTrigger RoutedEvent="MouseEnter">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation
                                                                    Storyboard.TargetName="OverlayBorder"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="#B3000000" Duration="0:0:0.15" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="RefreshIcon"
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                    To="1" Duration="0:0:0.15" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="RefreshIcon"
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                    To="1" Duration="0:0:0.15" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="RefreshIcon"
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    To="1" Duration="0:0:0.15" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="RefreshText"
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    To="1" Duration="0:0:0.15" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="RefreshIcon"
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(RotateTransform.Angle)"
                                                                    By="90" Duration="0:0:0.15" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <EventTrigger RoutedEvent="MouseLeave">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation
                                                                    Storyboard.TargetName="OverlayBorder"
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="#99000000" Duration="0:0:0.15" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="RefreshIcon"
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                    To="0.85" Duration="0:0:0.15" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="RefreshIcon"
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                    To="0.85" Duration="0:0:0.15" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="RefreshIcon"
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    To="0.9" Duration="0:0:0.15" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="RefreshText"
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    To="0.9" Duration="0:0:0.15" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Grid.Triggers>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Button x:Name="BackToMain"
                                            Grid.Row="3"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            materialDesign:ButtonAssist.CornerRadius="16"
                                            HorizontalAlignment="Center"
                                            Width="130"
                                            Height="32"
                                            ToolTip="返回主页面"
                                            Command="{Binding LoginPage.BackToMainPageCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ArrowLeft" Margin="0,0,8,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="返回" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </materialDesign:TransitionerSlide>

                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.BackwardWipe>
                                    <materialDesign:SlideWipe />
                                </materialDesign:TransitionerSlide.BackwardWipe>
                                <Grid Margin="24,0,24,0" VerticalAlignment="Center">
                                    <StackPanel>
                                        <ComboBox x:Name="ProcessSelection"
                                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                  materialDesign:HintAssist.Hint="{Binding InjectPage.ProcessSelectionHint}"
                                                  ItemsSource="{Binding InjectPage.FFXIVProcesses}"
                                                  SelectedItem="{Binding InjectPage.SelectedProcess}"
                                                  Margin="0,0,0,20">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                                        <materialDesign:PackIcon Kind="Forbid"
                                                                Height="16" Width="16"
                                                                Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                                                Margin="0,0,8,0"
                                                                Visibility="{Binding HasInjected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <CheckBox x:Name="AutoInjectCheckBox"
                                                  Content="自动注入"
                                                  IsChecked="{Binding InjectPage.AutoInjectEnabled}"
                                                  Margin="0,0,0,12"
                                                  ToolTip="勾选后, 当检测到未注入 Dalamud 的游戏进程时, 自动执行注入" />

                                        <Grid Margin="0,0,0,12">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger
                                                            Binding="{Binding ElementName=AutoInjectCheckBox, Path=IsChecked}"
                                                            Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="手动注入延迟"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBox Width="70"
                                                         Text="{Binding InjectPage.ManualInjectDelayMs}"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="ms"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.7" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="InjectButton"
                                                    Grid.Column="0"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="16"
                                                    Height="32"
                                                    Content="带回前台"
                                                    Command="{Binding InjectPage.BringProcessForegroundCommand}"
                                                    IsEnabled="{Binding InjectPage.CanOperateOnSelectedProcess}" />
                                            <Button x:Name="BringUp"
                                                    Grid.Column="2"
                                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="16"
                                                    Height="32"
                                                    Content="注  入"
                                                    Command="{Binding InjectPage.InjectGameCommand}"
                                                    IsEnabled="{Binding InjectPage.CanOperateOnSelectedProcess}" />
                                        </Grid>

                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                Command="{Binding InjectPage.ReturnToLoginPageCommand}"
                                                Margin="0,0,0,0" Height="24" Padding="8,0"
                                                HorizontalAlignment="Center"
                                                Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ArrowLeft" Width="12"
                                                                         Height="12" Margin="0,0,4,0"
                                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding InjectPage.ReturnButtonText}" FontSize="11"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:TransitionerSlide>

                            <!-- Dashboard：登录后主页面 -->
                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.ForwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:TransitionerSlide.BackwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.BackwardWipe>

                                <Grid Margin="24,0,24,0" VerticalAlignment="Center">
                                    <StackPanel>
                                        <Border Style="{StaticResource DashboardInfoCardStyle}" Margin="0,0,0,12">
                                            <Grid Margin="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="当前账号" FontSize="11" Opacity="0.6" />
                                                    <TextBlock Text="{Binding DashboardPage.AccountName}"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource HeaderUtilityButtonStyle}"
                                                        Width="28" Height="28"
                                                        VerticalAlignment="Center"
                                                        Tag="{Binding DashboardPage.AccountName}"
                                                        Click="CopyAccountField_OnClick"
                                                        ToolTip="复制账号">
                                                    <materialDesign:PackIcon Kind="ContentCopy" Width="16" Height="16"
                                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="选择大区" FontSize="11" Opacity="0.6" Margin="0,0,0,6" />

                                        <ListBox ItemsSource="{Binding DashboardPage.Areas}"
                                                 SelectedItem="{Binding DashboardPage.SelectedArea}"
                                                 Margin="0,0,0,14">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="1" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="2,0" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Grid>
                                                                    <Border x:Name="Bg"
                                                                            Background="Transparent"
                                                                            CornerRadius="8"
                                                                            BorderThickness="1"
                                                                            BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}" />
                                                                    <Border x:Name="ActiveBg"
                                                                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                                            CornerRadius="8" Opacity="0" />
                                                                    <TextBlock x:Name="Txt"
                                                                               Text="{Binding AreaName}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               FontSize="12" Padding="0,6"
                                                                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Trigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetName="ActiveBg"
                                                                                        Storyboard.TargetProperty="Opacity"
                                                                                        To="0.26" Duration="0:0:0.2">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <CubicEase EasingMode="EaseOut" />
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </Trigger.EnterActions>
                                                                        <Trigger.ExitActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetName="ActiveBg"
                                                                                        Storyboard.TargetProperty="Opacity"
                                                                                        To="0" Duration="0:0:0.2">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <CubicEase EasingMode="EaseOut" />
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </Trigger.ExitActions>
                                                                        <Setter TargetName="Bg" Property="BorderBrush"
                                                                                Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                                        <Setter TargetName="Txt" Property="Foreground"
                                                                                Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                                        <Setter TargetName="Txt" Property="FontWeight" Value="SemiBold" />
                                                                    </Trigger>
                                                                    <MultiTrigger>
                                                                        <MultiTrigger.Conditions>
                                                                            <Condition Property="IsMouseOver" Value="True" />
                                                                            <Condition Property="IsSelected" Value="False" />
                                                                        </MultiTrigger.Conditions>
                                                                        <Setter TargetName="Bg" Property="BorderBrush"
                                                                                Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                                        <Setter TargetName="Bg" Property="Opacity" Value="0.6" />
                                                                    </MultiTrigger>
                                                                </ControlTemplate.Triggers>
                                                 </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>

                                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="16"
                                                Height="52"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Command="{Binding DashboardPage.StartGameCommand}"
                                                Margin="0,0,0,8">
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="Play" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="启动游戏" VerticalAlignment="Center" />
                                                    <materialDesign:PackIcon Kind="MenuDown" Width="18" Height="18" Margin="4,0,0,0" VerticalAlignment="Center" Opacity="0.8" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding DashboardPage.GameVersion}"
                                                           FontSize="10"
                                                           FontWeight="Normal"
                                                           Opacity="0.6"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <Button.ContextMenu>
                                                <ContextMenu Style="{StaticResource LoginActionContextMenuStyle}">
                                                    <MenuItem Header="无 Dalamud 启动"
                                                              Style="{StaticResource LoginActionMenuItemStyle}"
                                                              Command="{Binding DashboardPage.StartGameNoDalamudCommand}" />
                                                    <MenuItem Header="禁用插件启动"
                                                              Style="{StaticResource LoginActionMenuItemStyle}"
                                                              Command="{Binding DashboardPage.StartGameNoPluginsCommand}" />
                                                    <MenuItem Header="禁用第三方插件启动"
                                                              Style="{StaticResource LoginActionMenuItemStyle}"
                                                              Command="{Binding DashboardPage.StartGameNoThirdCommand}" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>

                                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                materialDesign:ButtonAssist.CornerRadius="16"
                                                Height="36"
                                                FontSize="12"
                                                Command="{Binding DashboardPage.SwitchAccountCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="AccountSwitch" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                <TextBlock Text="切换账号" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <Button HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                Margin="0,8,0,0"
                                                Style="{StaticResource DalamudStatusButtonStyle}"
                                                Command="{Binding RefreshDalamudInfoCommand}"
                                                Visibility="{Binding Settings.EnableHooks, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Refresh" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center" Opacity="0.7" />
                                                <TextBlock Text="{Binding DalamudStatusText}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:TransitionerSlide>

                            <!-- DC Travel：超域传送页面 -->
                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.ForwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:TransitionerSlide.BackwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.BackwardWipe>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid Margin="16,0,16,0" VerticalAlignment="Center">
                                        <StackPanel>
                                            <!-- 维护提示横幅 -->
                                            <Border CornerRadius="8"
                                                    Padding="12,10,12,10"
                                                    Margin="0,0,0,12"
                                                    Background="#33FF9800"
                                                    BorderBrush="#66FF9800"
                                                    BorderThickness="1"
                                                    Visibility="{Binding DCTravelPage.IsUnderMaintenance, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="AlertCircle" Width="16" Height="16"
                                                                             Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding DCTravelPage.MaintenanceMessage}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#FF9800" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>

                                            <!-- 步骤一：出发角色 -->
                                            <Border BorderThickness="1" 
                                                    BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}"
                                                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                                                    CornerRadius="12"
                                                    Padding="10,8,10,8"
                                                    Margin="0,0,0,8">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <materialDesign:PackIcon Kind="AccountBox" Width="14" Height="14" 
                                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" 
                                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Grid.Column="1" Text="出发角色" FontSize="11" FontWeight="SemiBold" 
                                                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" VerticalAlignment="Center" />
                                                    </Grid>

                                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                              materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                              materialDesign:HintAssist.Hint="原始大区"
                                                              ItemsSource="{Binding DCTravelPage.SourceAreas}"
                                                              SelectedItem="{Binding DCTravelPage.SelectedSourceArea}"
                                                              DisplayMemberPath="AreaName"
                                                              Margin="0,0,0,8" />

                                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                              materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                              materialDesign:HintAssist.Hint="{Binding DCTravelPage.CharacterHint}"
                                                              SelectedItem="{Binding DCTravelPage.SelectedCharacter}"
                                                              IsEnabled="{Binding DCTravelPage.IsCharacterEnabled}"
                                                              Visibility="{Binding DCTravelPage.IsCharacterVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                              Margin="0,0,0,4">
                                                        <ComboBox.Resources>
                                                            <CollectionViewSource x:Key="CharactersView"
                                                                                  Source="{Binding DCTravelPage.Characters}">
                                                                <CollectionViewSource.GroupDescriptions>
                                                                    <PropertyGroupDescription PropertyName="ServerName" />
                                                                </CollectionViewSource.GroupDescriptions>
                                                            </CollectionViewSource>
                                                        </ComboBox.Resources>
                                                        <ComboBox.ItemsSource>
                                                            <Binding Source="{StaticResource CharactersView}" />
                                                        </ComboBox.ItemsSource>
                                                        <ComboBox.GroupStyle>
                                                            <GroupStyle>
                                                                <GroupStyle.HeaderTemplate>
                                                                    <DataTemplate DataType="{x:Type data:CollectionViewGroup}">
                                                                        <Grid Margin="0,6,0,2">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="*" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="{Binding Name}"
                                                                                       FontSize="11"
                                                                                       Opacity="0.5"
                                                                                       Margin="8,0,8,0"
                                                                                       VerticalAlignment="Center" />
                                                                            <Separator Grid.Column="1"
                                                                                       Margin="0,0,8,0"
                                                                                       Background="{DynamicResource MaterialDesign.Brush.Card.Border}"
                                                                                       VerticalAlignment="Center" />
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </GroupStyle.HeaderTemplate>
                                                            </GroupStyle>
                                                        </ComboBox.GroupStyle>
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Border>

                                            <!-- 步骤二：旅行目的地 (仅当选择原始角色大区后可见) -->
                                            <Border BorderThickness="1" 
                                                    BorderBrush="{DynamicResource MaterialDesign.Brush.Card.Border}"
                                                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                                                    CornerRadius="12"
                                                    Padding="10,8,10,8"
                                                    Margin="0,0,0,8"
                                                    Visibility="{Binding DCTravelPage.IsTargetAreaVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <materialDesign:PackIcon Kind="Compass" Width="14" Height="14" 
                                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" 
                                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Grid.Column="1" Text="旅行目的地" FontSize="11" FontWeight="SemiBold" 
                                                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" VerticalAlignment="Center" />
                                                    </Grid>

                                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                              materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                              materialDesign:HintAssist.Hint="目标大区"
                                                              ItemsSource="{Binding DCTravelPage.TargetAreas}"
                                                              SelectedItem="{Binding DCTravelPage.SelectedTargetArea}"
                                                              Visibility="{Binding DCTravelPage.IsTargetAreaVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                              Margin="0,0,0,8">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                                                        <Ellipse.Style>
                                                                            <Style TargetType="Ellipse">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding State}" Value="0">
                                                                                        <Setter Property="Fill" Value="MediumSeaGreen" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding State}" Value="1">
                                                                                        <Setter Property="Fill" Value="DarkOrange" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding State}" Value="2">
                                                                                        <Setter Property="Fill" Value="IndianRed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                                <Setter Property="Fill" Value="IndianRed" />
                                                                            </Style>
                                                                        </Ellipse.Style>
                                                                    </Ellipse>
                                                                    <TextBlock Text="{Binding AreaName}" VerticalAlignment="Center" />
                                                                    <TextBlock Margin="6,0,0,0" FontSize="11" Opacity="0.7" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding State}" Value="0">
                                                                                        <Setter Property="Text" Value="通畅" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding State}" Value="1">
                                                                                        <Setter Property="Text" Value="热门" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding State}" Value="2">
                                                                                        <Setter Property="Text" Value="火爆" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                                <Setter Property="Text" Value="繁忙" />
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>

                                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                              materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                              materialDesign:HintAssist.Hint="目标服务器"
                                                              ItemsSource="{Binding DCTravelPage.TargetGroups}"
                                                              SelectedItem="{Binding DCTravelPage.SelectedTargetGroup}"
                                                              Visibility="{Binding DCTravelPage.IsTargetGroupVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                              Margin="0,0,0,4">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                                                        <Ellipse.Style>
                                                                            <Style TargetType="Ellipse">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding QueueTime}" Value="{x:Null}">
                                                                                        <Setter Property="Fill" Value="LightSlateGray" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding QueueTime}" Value="0">
                                                                                        <Setter Property="Fill" Value="MediumSeaGreen" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                                <Setter Property="Fill" Value="IndianRed" />
                                                                            </Style>
                                                                        </Ellipse.Style>
                                                                    </Ellipse>
                                                                    <TextBlock Text="{Binding GroupName}" VerticalAlignment="Center" />
                                                                    <TextBlock Margin="6,0,0,0" FontSize="11" Opacity="0.7" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding QueueTime}" Value="{x:Null}">
                                                                                        <Setter Property="Text" Value="读取中" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding QueueTime}" Value="0">
                                                                                        <Setter Property="Text" Value="通畅" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                                <Setter Property="Text" Value="繁忙" />
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Border>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                                        materialDesign:ButtonAssist.CornerRadius="16"
                                                        Height="36" FontSize="12"
                                                        Command="{Binding DCTravelPage.TravelOrderCommand}"
                                                        IsEnabled="{Binding DCTravelPage.CanTravelOrder}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Rocket" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="超域旅行" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                                        materialDesign:ButtonAssist.CornerRadius="16"
                                                        Height="36" FontSize="12"
                                                        Command="{Binding DCTravelPage.OpenHistoryCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="History" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="历史" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                    Command="{Binding DCTravelPage.BackToDashboardCommand}"
                                                    Margin="0,0,0,4" Height="24" Padding="8,0"
                                                    HorizontalAlignment="Center"
                                                    Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ArrowLeft" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="返回" FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </materialDesign:TransitionerSlide>

                            <!-- DC Travel 历史记录 -->
                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.ForwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:TransitionerSlide.BackwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.BackwardWipe>

                                <Grid Margin="20,0,20,0" VerticalAlignment="Center">
                                    <StackPanel>
                                        <!-- 无订单时的 Empty State -->
                                         <StackPanel Visibility="{Binding DCTravelPage.HasNoMigrationOrders, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                     Margin="0,20,0,24" HorizontalAlignment="Center">
                                             <materialDesign:PackIcon Kind="History" Width="48" Height="48"
                                                                      Opacity="0.25" HorizontalAlignment="Center" 
                                                                      Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
                                             <TextBlock Text="暂无超域旅行历史记录" FontSize="12" FontWeight="SemiBold"
                                                        Opacity="0.4" Margin="0,12,0,0" HorizontalAlignment="Center" />
                                             <TextBlock Text="可在上一步选择角色进行超域传送" FontSize="10"
                                                        Opacity="0.3" Margin="0,4,0,0" HorizontalAlignment="Center" />
                                         </StackPanel>

                                         <!-- 订单轨迹卡片列表 -->
                                         <ListBox ItemsSource="{Binding DCTravelPage.MigrationOrders}"
                                                  SelectedItem="{Binding DCTravelPage.SelectedOrder}"
                                                  Visibility="{Binding DCTravelPage.HasMigrationOrders, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  MaxHeight="260"
                                                  Margin="0,0,0,12"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  HorizontalContentAlignment="Stretch">
                                             <ListBox.ItemContainerStyle>
                                                 <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                     <Setter Property="Padding" Value="0" />
                                                     <Setter Property="Margin" Value="0,0,0,8" />
                                                     <Setter Property="Background" Value="Transparent" />
                                                     <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                     <Setter Property="Template">
                                                         <Setter.Value>
                                                             <ControlTemplate TargetType="ListBoxItem">
                                                                 <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                   VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                                   SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                             </ControlTemplate>
                                                         </Setter.Value>
                                                     </Setter>
                                                 </Style>
                                             </ListBox.ItemContainerStyle>
                                             <ListBox.ItemTemplate>
                                                 <DataTemplate>
                                                     <Border CornerRadius="8">
                                                         <Border.Style>
                                                             <Style TargetType="Border">
                                                                 <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}" />
                                                                 <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Card.Border}" />
                                                                 <Setter Property="BorderThickness" Value="1" />
                                                                 <Setter Property="Padding" Value="10,8" />
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                                         <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                         <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                                         <Setter Property="BorderThickness" Value="2" />
                                                                         <Setter Property="Padding" Value="9,7" />
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Border.Style>
                                                         <Grid>
                                                             <Grid.RowDefinitions>
                                                                 <RowDefinition Height="Auto" />
                                                                 <RowDefinition Height="Auto" />
                                                                 <RowDefinition Height="Auto" />
                                                             </Grid.RowDefinitions>

                                                             <!-- 第一行：角色信息与时间 -->
                                                             <Grid Grid.Row="0">
                                                                 <Grid.ColumnDefinitions>
                                                                     <ColumnDefinition Width="*" />
                                                                     <ColumnDefinition Width="Auto" />
                                                                 </Grid.ColumnDefinitions>
                                                                 
                                                                 <StackPanel Orientation="Horizontal" Grid.Column="0">
                                                                     <materialDesign:PackIcon Kind="Account" Width="12" Height="12" 
                                                                                              Foreground="{DynamicResource MaterialDesign.Brush.Primary}" 
                                                                                              VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                     <TextBlock Text="{Binding RoleName}" 
                                                                                FontSize="11" 
                                                                                FontWeight="SemiBold" 
                                                                                Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                                                                VerticalAlignment="Center"/>
                                                                 </StackPanel>

                                                                 <TextBlock Grid.Column="1" 
                                                                            Text="{Binding CreateTime}" 
                                                                            FontSize="9" 
                                                                            Opacity="0.5" 
                                                                            VerticalAlignment="Center"/>
                                                             </Grid>

                                                             <!-- 第二行：超域轨迹 (源服务器 -> 目标服务器) -->
                                                             <Border Grid.Row="1" 
                                                                     Background="#08FFFFFF" 
                                                                     CornerRadius="4" 
                                                                     Margin="0,6,0,6" 
                                                                     Padding="6,4">
                                                                 <Grid>
                                                                     <Grid.ColumnDefinitions>
                                                                         <ColumnDefinition Width="*" />
                                                                         <ColumnDefinition Width="Auto" />
                                                                         <ColumnDefinition Width="*" />
                                                                     </Grid.ColumnDefinitions>

                                                                     <StackPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                         <TextBlock Text="{Binding SourceAreaName}" FontSize="8" Opacity="0.5" HorizontalAlignment="Left"/>
                                                                         <TextBlock Text="{Binding SourceGroupName}" FontSize="10" FontWeight="Medium" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Margin="0,1,0,0" HorizontalAlignment="Left"/>
                                                                     </StackPanel>

                                                                     <materialDesign:PackIcon Grid.Column="1" 
                                                                                              Kind="ChevronDoubleRight" 
                                                                                              Width="12" Height="12" 
                                                                                              Foreground="{DynamicResource MaterialDesign.Brush.Primary}" 
                                                                                              VerticalAlignment="Center" 
                                                                                              HorizontalAlignment="Center" 
                                                                                              Margin="4,0,4,0"/>

                                                                     <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                         <TextBlock Text="{Binding TargetAreaName}" FontSize="8" Opacity="0.5" HorizontalAlignment="Right"/>
                                                                         <TextBlock Text="{Binding TargetGroupName}" FontSize="10" FontWeight="Medium" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Margin="0,1,0,0" HorizontalAlignment="Right"/>
                                                                     </StackPanel>
                                                                 </Grid>
                                                             </Border>

                                                             <!-- 第三行：状态 -->
                                                             <Grid Grid.Row="2">
                                                                 <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                     <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                                                         <Ellipse.Style>
                                                                             <Style TargetType="Ellipse">
                                                                                 <Setter Property="Fill" Value="LightSlateGray" />
                                                                                 <Style.Triggers>
                                                                                     <DataTrigger Binding="{Binding TravelStatus}" Value="1">
                                                                                         <Setter Property="Fill" Value="MediumSeaGreen" />
                                                                                     </DataTrigger>
                                                                                 </Style.Triggers>
                                                                             </Style>
                                                                         </Ellipse.Style>
                                                                     </Ellipse>
                                                                     <TextBlock FontSize="10" VerticalAlignment="Center">
                                                                         <TextBlock.Style>
                                                                             <Style TargetType="TextBlock">
                                                                                 <Setter Property="Text" Value="已返回" />
                                                                                 <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                                                                                 <Setter Property="Opacity" Value="0.6" />
                                                                                 <Style.Triggers>
                                                                                     <DataTrigger Binding="{Binding TravelStatus}" Value="1">
                                                                                         <Setter Property="Text" Value="已抵达" />
                                                                                         <Setter Property="Foreground" Value="MediumSeaGreen" />
                                                                                         <Setter Property="Opacity" Value="1.0" />
                                                                                     </DataTrigger>
                                                                                 </Style.Triggers>
                                                                             </Style>
                                                                         </TextBlock.Style>
                                                                     </TextBlock>
                                                                 </StackPanel>
                                                             </Grid>
                                                         </Grid>
                                                     </Border>
                                                 </DataTemplate>
                                             </ListBox.ItemTemplate>
                                         </ListBox>


                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="16"
                                                    Height="36" FontSize="12"
                                                    Command="{Binding DCTravelPage.TravelBackCommand}"
                                                    IsEnabled="{Binding DCTravelPage.IsNotLoading}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ArrowLeftBold" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="超域返回" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="16"
                                                    Height="36" FontSize="12"
                                                    Command="{Binding DCTravelPage.RefreshOrdersCommand}"
                                                    IsEnabled="{Binding DCTravelPage.IsNotLoading}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="刷新" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                Command="{Binding DCTravelPage.BackToTravelCommand}"
                                                Margin="0,0,0,4" Height="24" Padding="8,0"
                                                HorizontalAlignment="Center"
                                                Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ArrowLeft" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                <TextBlock Text="返回" FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:TransitionerSlide>

                            <!-- DC Travel 传送进度 -->
                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.ForwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:TransitionerSlide.BackwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.BackwardWipe>

                                <Grid Margin="24,0,24,0" VerticalAlignment="Center">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,20" Width="80" Height="80" HorizontalAlignment="Center">
                                            <Ellipse Fill="{DynamicResource MaterialDesign.Brush.Primary}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" Width="48" Height="48">
                                                <Ellipse.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                                 From="48" To="80" Duration="0:0:1.5"
                                                                                 AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                 From="48" To="80" Duration="0:0:1.5"
                                                                                 AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="1" To="0.35" Duration="0:0:1.5"
                                                                                 AutoReverse="True" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Ellipse.Triggers>
                                            </Ellipse>
                                            <materialDesign:PackIcon Kind="Rocket" Width="24" Height="24"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                                        </Grid>

                                        <TextBlock Text="{Binding DCTravelPage.TravelProgressText}"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,20" />

                                        <Button Content="返回"
                                                Command="{Binding DCTravelPage.ReturnFromProgressCommand}"
                                                materialDesign:ButtonAssist.CornerRadius="16"
                                                HorizontalAlignment="Center"
                                                Width="120">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DCTravelPage.IsTravelInProgress}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:TransitionerSlide>

                            <!-- DC Travel 超域返回 -->
                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.ForwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:TransitionerSlide.BackwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.BackwardWipe>

                                <Grid Margin="20,0,20,0" VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="超域返回" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                                        <Border Style="{StaticResource DashboardInfoCardStyle}" Padding="10" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="返回订单" FontSize="11" Opacity="0.6" />
                                                <TextBlock Text="{Binding DCTravelPage.ReturnOrderInfo}" FontSize="13" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Border>
                                        
                                        <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                  materialDesign:HintAssist.Hint="当前大区"
                                                  ItemsSource="{Binding DCTravelPage.ReturnSourceAreas}"
                                                  SelectedItem="{Binding DCTravelPage.ReturnSelectedSourceArea}"
                                                  DisplayMemberPath="AreaName"
                                                  Margin="0,0,0,8" />

                                        <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  materialDesign:TextFieldAssist.TextFieldCornerRadius="8"
                                                  materialDesign:HintAssist.Hint="当前服务器"
                                                  ItemsSource="{Binding DCTravelPage.ReturnCurrentGroups}"
                                                  SelectedItem="{Binding DCTravelPage.ReturnSelectedCurrentGroup}"
                                                  DisplayMemberPath="GroupName"
                                                  Margin="0,0,0,16" />

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="16"
                                                    Height="36" FontSize="12"
                                                    Command="{Binding DCTravelPage.ConfirmTravelBackCommand}"
                                                    IsEnabled="{Binding DCTravelPage.IsNotLoading}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ArrowLeftBold" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="确认" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    materialDesign:ButtonAssist.CornerRadius="16"
                                                    Height="36" FontSize="12"
                                                    Command="{Binding DCTravelPage.CancelReturnCommand}">
                                                <TextBlock Text="取消" VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>

                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                Command="{Binding DCTravelPage.CancelReturnCommand}"
                                                Margin="0,0,0,4" Height="24" Padding="8,0"
                                                HorizontalAlignment="Center"
                                                Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ArrowLeft" Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                <TextBlock Text="返回" FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:TransitionerSlide>
                            <!-- 账户管理器 Slide (Index 9) -->
                            <materialDesign:TransitionerSlide>
                                <materialDesign:TransitionerSlide.ForwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.ForwardWipe>
                                <materialDesign:TransitionerSlide.BackwardWipe>
                                    <transitions:StableFadeWipe />
                                </materialDesign:TransitionerSlide.BackwardWipe>

                                <Grid Margin="16,12,16,12" VerticalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- 顶部导航条 -->
                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                Width="30" Height="30" Padding="0"
                                                Command="{Binding LoginPage.BackToMainPageCommand}"
                                                ToolTip="返回登录界面">
                                            <materialDesign:PackIcon Kind="ArrowLeft" Width="20" Height="20"
                                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                        </Button>
                                        <TextBlock Grid.Column="1"
                                                   Text="账号"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <ListView Grid.Row="1" DataContext="{Binding AccountSwitcher}"
                                    x:Name="AccountListView"
                                    AllowDrop="True"
                                    BorderThickness="0"
                                    Drop="AccountListView_OnDrop"
                                    ItemsSource="{Binding Entries}"
                                    MouseUp="AccountListView_OnMouseUp"
                                    PreviewMouseLeftButtonDown="AccountListView_OnPreviewMouseLeftButtonDown"
                                    PreviewMouseRightButtonDown="AccountListView_OnPreviewMouseRightButtonDown"
                                    PreviewMouseMove="AccountListView_OnPreviewMouseMove"
                                    SelectionMode="Single"
                                    
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    SelectedItem="{Binding SelectedEntry}">
                                    <ListView.ContextMenu>
                                    <ContextMenu Language="zh-CN"
                                    Closed="AccountListViewContextMenu_OnClosed"
                                    Style="{StaticResource MaterialDesignContextMenu}">
                                    <ContextMenu.Resources>
                                    <Style TargetType="{x:Type MenuItem}"
                                    BasedOn="{StaticResource MaterialDesignMenuItem}">
                                    <Setter Property="Height" Value="36" />
                                    <Setter Property="Foreground"
                                    Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                                    </Style>
                                    <Style TargetType="{x:Type Separator}"
                                    BasedOn="{StaticResource MaterialDesignSeparator}">
                                    <Setter Property="Margin" Value="0,4" />
                                    </Style>
                                    </ContextMenu.Resources>
                                    <MenuItem
                                    Command="{Binding SetProfilePictureCommand}"
                                    Header="设置账号信息">
                                    <MenuItem.Icon>
                                    <materialDesign:PackIcon
                                    Kind="AccountEditOutline" />
                                    </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem
                                    Command="{Binding ConfigureDeviceProfileCommand}"
                                    Header="设置设备信息">
                                    <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Devices" />
                                    </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator Margin="0 8" />
                                    <MenuItem
                                    Command="{Binding CreateDesktopShortcutCommand}"
                                    Header="创建桌面快捷方式">
                                    <MenuItem.Icon>
                                    <materialDesign:PackIcon
                                    Kind="LinkVariant" />
                                    </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator Margin="0 8" />
                                    <MenuItem
                                    Header="不保存密码"
                                    IsCheckable="True"
                                    IsChecked="{Binding IsSelectedAccountPasswordNotSaved, Mode=TwoWay}" />
                                    <Separator Margin="0 8" />
                                    <MenuItem
                                    Command="{Binding RemoveAccountCommand}"
                                    Foreground="#E57373"
                                    Header="移除">
                                    <MenuItem.Icon>
                                    <materialDesign:PackIcon
                                    Kind="DeleteOutline" />
                                    </MenuItem.Icon>
                                    </MenuItem>
                                    </ContextMenu>
                                    </ListView.ContextMenu>
                                    
                                    <ListView.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Margin" Value="6,8,6,4" />
                                        <Setter Property="Padding" Value="10,8" />
                                        <Setter Property="ClipToBounds" Value="False" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="MainContainer"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            RenderTransformOrigin="0.5,0.5"
                                                            Margin="0"
                                                            ClipToBounds="False">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
                                                        </Border.RenderTransform>
                                                        <Grid>
                                                            <!-- 默认卡片底色 (微透深卡片) -->
                                                            <Border x:Name="CardBorder"
                                                                    Background="#08FFFFFF"
                                                                    BorderBrush="#0FFFFFFF"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8" />

                                                            <!-- Hover 状态覆盖层 -->
                                                            <Border x:Name="HoverBorder"
                                                                    Background="#12FFFFFF"
                                                                    BorderBrush="#88FF8F00"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Opacity="0" />

                                                            <!-- Selected 状态覆盖层 -->
                                                            <Border x:Name="SelectedBorder"
                                                                    Background="#18FF8F00"
                                                                    BorderBrush="#FF8F00"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Opacity="0" />

                                                            <!-- 左侧橙色发光指示条 -->
                                                            <Border x:Name="SelectedIndicator"
                                                                    Width="3" Height="18"
                                                                    Background="#FF8F00"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    CornerRadius="1.5"
                                                                    Opacity="0"
                                                                    Margin="5,0,0,0" />

                                                            <!-- 项目内容呈现 -->
                                                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <!-- Hover 动画 -->
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.15" />
                                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.15" />
                                                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12" />
                                                                        <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12" />
                                                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>

                                                        <!-- Selected 动画 -->
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="SelectedBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                                                        <DoubleAnimation Storyboard.TargetName="SelectedIndicator" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="SelectedBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12" />
                                                                        <DoubleAnimation Storyboard.TargetName="SelectedIndicator" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                 </ControlTemplate>
                                    </Setter.Value>
                                    </Setter>
                                    </Style>
                                    </ListView.ItemContainerStyle>
                                    
                                    <ListView.ItemTemplate>
                                    <DataTemplate x:Name="AccountDataTemplate"
                                    DataType="mainWindow:AccountSwitcherEntry">
                                    <Grid>
                                    <Grid.ToolTip>
                                    <ToolTip Placement="Right">
                                    <StackPanel>
                                    <TextBlock Text="{Binding Account.DisplayName}"
                                    FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Account.UserName}"
                                    Opacity="0.7" Margin="0,2,0,0">
                                    <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                    <DataTrigger
                                    Binding="{Binding Account.UserDefinedName}"
                                    Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger
                                    Binding="{Binding Account.UserDefinedName}"
                                    Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    </Style.Triggers>
                                    </Style>
                                    </TextBlock.Style>
                                    </TextBlock>
                                    </StackPanel>
                                    </ToolTip>
                                    </Grid.ToolTip>
                                    <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Margin="2,0,0,0">
                                    <Ellipse Width="38" Height="38">
                                    <Ellipse.Fill>
                                    <ImageBrush
                                    ImageSource="{Binding ProfileImage}"
                                    Stretch="UniformToFill" />
                                    </Ellipse.Fill>
                                    </Ellipse>
                                    <Ellipse Width="38" Height="38"
                                    Stroke="{DynamicResource MaterialDesign.Brush.Card.Border}"
                                    StrokeThickness="1" Opacity="0.5" />
                                    </Grid>

                                    <StackPanel Grid.Column="1"
                                    Margin="10,0,6,0"
                                    VerticalAlignment="Center">
                                    <Grid>
                                    <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                    Text="{Binding Account.DisplayName}"
                                    FontSize="14" FontWeight="SemiBold"
                                    TextWrapping="Wrap"
                                    LineHeight="17"
                                    LineStackingStrategy="BlockLineHeight"
                                    MaxHeight="34"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1"
                                    Style="{StaticResource AccountFieldCopyButtonStyle}"
                                    Tag="{Binding Account.DisplayName}"
                                    Click="CopyAccountField_OnClick"
                                    ToolTip="复制">
                                    <materialDesign:PackIcon Kind="ContentCopy" Width="13" Height="13" />
                                    </Button>
                                    </Grid>
                                    <Grid Margin="0,2,0,0">
                                    <Grid.Style>
                                    <Style TargetType="Grid">
                                    <Style.Triggers>
                                    <DataTrigger
                                    Binding="{Binding Account.UserDefinedName}"
                                    Value="">
                                    <Setter
                                    Property="Visibility"
                                    Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger
                                    Binding="{Binding Account.UserDefinedName}"
                                    Value="{x:Null}">
                                    <Setter
                                    Property="Visibility"
                                    Value="Collapsed" />
                                    </DataTrigger>
                                    </Style.Triggers>
                                    </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                    Text="{Binding Account.UserName}"
                                    FontSize="11" Opacity="0.6"
                                    TextWrapping="Wrap"
                                    LineHeight="14"
                                    LineStackingStrategy="BlockLineHeight"
                                    MaxHeight="28"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1"
                                    Style="{StaticResource AccountFieldCopyButtonStyle}"
                                    Tag="{Binding Account.UserName}"
                                    Click="CopyAccountField_OnClick"
                                    ToolTip="复制">
                                    <materialDesign:PackIcon Kind="ContentCopy" Width="12" Height="12" />
                                    </Button>
                                    </Grid>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                    <materialDesign:PackIcon Height="16"
                                    Width="16" Margin="3,0,0,0"
                                    Opacity="0.5">
                                    <materialDesign:PackIcon.Style>
                                    <Style
                                    TargetType="materialDesign:PackIcon">
                                    <Style.Triggers>
                                    <DataTrigger
                                    Binding="{Binding Account.IsWeGame}"
                                    Value="true">
                                    <Setter
                                    Property="Kind"
                                    Value="Qqchat" />
                                    </DataTrigger>
                                    <DataTrigger
                                    Binding="{Binding Account.IsWeGame}"
                                    Value="false">
                                    <Setter
                                    Property="Visibility"
                                    Value="Collapsed" />
                                    </DataTrigger>
                                    </Style.Triggers>
                                    </Style>
                                    </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                    
                                    <materialDesign:PackIcon Height="16"
                                    Width="16" Margin="3,0,0,0"
                                    Opacity="0.5">
                                    <materialDesign:PackIcon.Style>
                                    <Style
                                    TargetType="materialDesign:PackIcon">
                                    <Style.Triggers>
                                    <DataTrigger
                                    Binding="{Binding Account.QuickLoginEnabled}"
                                    Value="True">
                                    <Setter
                                    Property="Kind"
                                    Value="AccountKeyOutline" />
                                    </DataTrigger>
                                    <DataTrigger
                                    Binding="{Binding Account.QuickLoginEnabled}"
                                    Value="False">
                                    <Setter
                                    Property="Visibility"
                                    Value="Collapsed" />
                                    </DataTrigger>
                                    </Style.Triggers>
                                    </Style>
                                    </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                    </StackPanel>
                                    </Grid>
                                    </DataTemplate>
                                    </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </materialDesign:TransitionerSlide>
                        </materialDesign:Transitioner>

                        <!-- 快捷入口（仅 Dashboard 显示） -->
                        <StackPanel Grid.Row="2" Margin="16,0,16,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding ElementName=LoginCardTransitioner, Path=SelectedIndex}"
                                            Value="4">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- 超域传送（Dashboard 内跳转到 DC Travel 页面） -->
                                <Button Grid.Row="0" Grid.Column="0"
                                        Command="{Binding DashboardPage.OpenDCTravelCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryQuickLinkButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DashboardPage.IsDCTravelUnderMaintenance}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5" />
                                                    <Setter Property="ToolTip">
                                                        <Setter.Value>
                                                            <ToolTip>
                                                                <TextBlock Text="超域旅行服务维护中, 请稍后再试" FontSize="12" />
                                                            </ToolTip>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Rocket" Width="14" Height="14"
                                                                 Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="超域传送" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DashboardPage.IsDCTravelUnderMaintenance}" Value="True">
                                                            <Setter Property="Text" Value="超域传送 (维护中)" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <!-- 购卡充值 -->
                                <Button Grid.Row="0" Grid.Column="2"
                                        Style="{StaticResource QuickLinkButtonStyle}"
                                        Click="PayPageButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ClockPlus" Width="14" Height="14"
                                                                 Margin="0,0,4,0" VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                        <TextBlock Text="购卡充值" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>

                                <!-- 商城中心 -->
                                <Button Grid.Row="2" Grid.Column="0"
                                        Style="{StaticResource QuickLinkButtonStyle}"
                                        Click="ShoppingPageButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Cart" Width="14" Height="14"
                                                                 Margin="0,0,4,0" VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                        <TextBlock Text="商城中心" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>

                                <!-- 官方账号 -->
                                <Button x:Name="OfficialAccountsButton"
                                        Grid.Row="2"
                                        Grid.Column="2"
                                        Style="{StaticResource QuickLinkButtonStyle}">
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="Button.Click">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <BooleanAnimationUsingKeyFrames
                                                        Storyboard.TargetName="OfficialAccountsPopup"
                                                        Storyboard.TargetProperty="IsOpen">
                                                        <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True" />
                                                    </BooleanAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountGroup" Width="14" Height="14"
                                                                 Margin="0,0,4,0" VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                        <TextBlock Text="官方账号" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>

                                <Popup x:Name="OfficialAccountsPopup"
                                       Grid.Row="2"
                                       Grid.Column="2"
                                       AllowsTransparency="True"
                                       Placement="Top"
                                       PlacementTarget="{Binding ElementName=OfficialAccountsButton}"
                                       PopupAnimation="None"
                                       StaysOpen="False"
                                       VerticalOffset="-6">
                                    <materialDesign:Card
                                        Background="{DynamicResource MaterialDesign.Brush.Background}"
                                        UniformCornerRadius="8"
                                        materialDesign:ElevationAssist.Elevation="Dp4">
                                        <StackPanel Margin="4">
                                            <Button Style="{StaticResource SocialSiteButtonStyle}"
                                                    Tag="{x:Static constant:Links.SDO_DOUYIN_URL}"
                                                    Click="OpenExternalSiteButton_OnClick">
                                                <StackPanel Orientation="Horizontal">
                                                    <mahIcon:PackIconSimpleIcons Width="16"
                                                            Height="16"
                                                            Kind="TikTok"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                    <TextBlock Text="抖音" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource SocialSiteButtonStyle}"
                                                    Tag="{x:Static constant:Links.SDO_XIAOHONGSHU_URL}"
                                                    Click="OpenExternalSiteButton_OnClick">
                                                <StackPanel Orientation="Horizontal">
                                                    <mahIcon:PackIconSimpleIcons Width="16"
                                                            Height="16"
                                                            Kind="Xiaohongshu"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                    <TextBlock Text="小红书" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource SocialSiteButtonStyle}"
                                                    Tag="{x:Static constant:Links.SDO_WEIBO_URL}"
                                                    Click="OpenExternalSiteButton_OnClick">
                                                <StackPanel Orientation="Horizontal">
                                                    <mahIcon:PackIconSimpleIcons Width="16"
                                                            Height="16"
                                                            Kind="SinaWeibo"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                    <TextBlock Text="微博" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource SocialSiteButtonStyle}"
                                                    Tag="{x:Static constant:Links.SDO_BILIBILI_URL}"
                                                    Click="OpenExternalSiteButton_OnClick">
                                                <StackPanel Orientation="Horizontal">
                                                    <mahIcon:PackIconSimpleIcons Width="16"
                                                            Height="16"
                                                            Kind="Bilibili"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                    <TextBlock Text="哔哩哔哩" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </Popup>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <materialDesign:DialogHost
                Identifier="MaintenanceQueueDialogHost"
                x:Name="MaintenanceQueueDialogHost"
                IsOpen="{Binding IsLoadingDialogOpen}">
                <materialDesign:DialogHost.DialogContent>
                    <StackPanel Margin="16">
                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="LoadingMessageTextBlock"
                                       Text="{Binding LoadingDialogMessage}" />
                            <ProgressBar

                                Style="{StaticResource MaterialDesignCircularProgressBar}"
                                Value="0"
                                IsIndeterminate="{Binding IsLoadingDialogOpen}" Height="30" Width="30"
                                Margin="0 8 0 0" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:DialogHost.DialogContent>
            </materialDesign:DialogHost>
        </Grid>

        <materialDesign:Snackbar x:Name="CopySnackbar"
                                 MessageQueue="{materialDesign:MessageQueue}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Bottom"
                                 Margin="0,0,0,16" />
    </Grid>
</Window>
