<Window
    x:Class="XIVLauncher.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:windows="clr-namespace:XIVLauncher.Windows"
    xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
    xmlns:site="clr-namespace:XIVLauncher.Common.Http.Site;assembly=XIVLauncher.Common"
    mc:Ignorable="d"
    Title="XIVLauncherCN (Soil)"
    Width="700"
    Height="420"
    UseLayoutRounding="True"
    ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
    Icon="pack://application:,,,/Resources/dalamud_icon.ico"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    Background="{DynamicResource MaterialDesignPaper}"
    TextElement.FontWeight="Bold" Closing="MainWindow_OnClosing"
    d:DataContext="{d:DesignInstance viewModel:MainWindowViewModel}">

    <Window.Resources>
        <system:Double x:Key="BannerCardWidth">399</system:Double>
        <system:Double x:Key="BannerCardHeight">213</system:Double>
        <Style x:Key="LoginActionContextMenuStyle"
               TargetType="{x:Type ContextMenu}"
               BasedOn="{StaticResource MaterialDesignContextMenu}" />
        <Style x:Key="LoginActionMenuItemStyle"
               TargetType="{x:Type MenuItem}"
               BasedOn="{StaticResource MaterialDesignMenuItem}" />
        <Style x:Key="LoginActionSeparatorStyle"
               TargetType="{x:Type Separator}"
               BasedOn="{StaticResource MaterialDesignSeparator}" />
    </Window.Resources>

    <Grid SnapsToDevicePixels="True" ClipToBounds="True">
        <materialDesign:Transitioner SelectedIndex="1">
            <materialDesign:Transitioner.CacheMode>
                <media:BitmapCache />
            </materialDesign:Transitioner.CacheMode>

            <materialDesign:TransitionerSlide>
                <materialDesign:TransitionerSlide.ForwardWipe>
                    <materialDesign:FadeWipe />
                </materialDesign:TransitionerSlide.ForwardWipe>
                <windows:SettingsControl x:Name="SettingsControl"
                                         DataContext="{Binding Settings}">
                    <windows:SettingsControl.CacheMode>
                        <media:BitmapCache />
                    </windows:SettingsControl.CacheMode>
                </windows:SettingsControl>
            </materialDesign:TransitionerSlide>

            <materialDesign:TransitionerSlide>
                <materialDesign:TransitionerSlide.BackwardWipe>
                    <materialDesign:FadeWipe />
                </materialDesign:TransitionerSlide.BackwardWipe>
                <Grid>
                    <Grid.CacheMode>
                        <media:BitmapCache />
                    </Grid.CacheMode>
                    <Grid Margin="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <materialDesign:Card
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0"
                                HorizontalAlignment="Left"
                                UniformCornerRadius="6"
                                Width="{DynamicResource BannerCardWidth}" Height="{DynamicResource BannerCardHeight}"
                                Cursor="Hand"
                                MouseUp="BannerCard_MouseUp">
                                <Grid>
                                    <Image x:Name="BannerImage"
                                           Stretch="UniformToFill"
                                           Source="pack://application:,,,/Resources/placeholder-news.png" />
                                </Grid>
                            </materialDesign:Card>

                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,10,10"
                                    Background="Transparent">
                                <ItemsControl x:Name="BannerDot" d:ItemsSource="{d:SampleData ItemCount=5}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModel:BannerDotInfo}">
                                            <RadioButton GroupName="banner"
                                                         IsChecked="{Binding Active, Mode=OneWay}"
                                                         Checked="BannerDot_OnChecked"
                                                         MouseEnter="RadioButton_MouseEnter"
                                                         MouseLeave="RadioButton_MouseLeave"
                                                         Margin="3,0"
                                                         Cursor="Hand"
                                                         Style="{StaticResource {x:Type ToggleButton}}">
                                                <RadioButton.Template>
                                                    <ControlTemplate TargetType="RadioButton">
                                                        <Border x:Name="DotBorder"
                                                                Width="8" Height="8"
                                                                CornerRadius="4"
                                                                Background="#88FFFFFF" />
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="DotBorder" Property="Background" Value="#FFFFFFFF" />
                                                                <Setter TargetName="DotBorder" Property="Width" Value="18" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="DotBorder" Property="Background" Value="#CCFFFFFF" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </RadioButton.Template>
                                            </RadioButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <materialDesign:Card
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0 12 0 4"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Left" 
                                Width="{DynamicResource BannerCardWidth}">
                                <ListBox x:Name="NewsListView"
                                         MouseUp="NewsListView_OnMouseUp"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="4,2"
                                         ScrollViewer.CanContentScroll="True"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         HorizontalContentAlignment="Stretch">
                                    <ListBox.Template>
                                        <ControlTemplate TargetType="ListBox">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                                <ScrollViewer
                                                    Focusable="False"
                                                    CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                                    HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                    VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                                    <ItemsPresenter />
                                                </ScrollViewer>
                                            </Border>
                                        </ControlTemplate>
                                    </ListBox.Template>
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem"
                                               BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="MinHeight" Value="32" />
                                            <Setter Property="Padding" Value="6,4,6,4" />
                                            <Setter Property="Margin" Value="0,1" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:Name="SingleLineDataTemplate"
                                                      DataType="site:News">
                                            <Grid Background="Transparent">
                                                <Grid.ToolTip>
                                                    <ToolTip Placement="Right">
                                                        <TextBlock>
                                                            <Run Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" 
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                                                 FontWeight="SemiBold"/>
                                                            <Run Text="  " />
                                                            <Run Text="{Binding Title}" />
                                                        </TextBlock>
                                                    </ToolTip>
                                                </Grid.ToolTip>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <Border Grid.Column="0" 
                                                        Background="{DynamicResource PrimaryHueMidBrush}" 
                                                        Opacity="0.12"
                                                        CornerRadius="4" 
                                                        VerticalAlignment="Center">
                                                </Border>
                                                <TextBlock Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Padding="0 2 4 2"
                                                           Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" />

                                                <TextBlock Grid.Column="1"
                                                           Margin="4,0,4,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           LineHeight="16"
                                                           Text="{Binding Title}"
                                                           TextWrapping="Wrap" />
                                                           
                                                <materialDesign:PackIcon Grid.Column="2" 
                                                                         Kind="ChevronRight" 
                                                                         VerticalAlignment="Center" 
                                                                         Width="14" Height="14" 
                                                                         Opacity="0.4" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </materialDesign:Card>



                            <materialDesign:Card
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Width="260"
                                Margin="8 0 0 4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                SnapsToDevicePixels="True"
                                ClipToBounds="True"
                                KeyDown="Card_KeyDown">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="8,8,8,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=LoginCardTransitioner, Path=SelectedIndex}" Value="1">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Left">
                                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="4"
                                                    Focusable="False"
                                                    Cursor="Hand"
                                                    Tag="https://space.bilibili.com/6655514"
                                                    Click="OpenExternalSiteButton_OnClick">
