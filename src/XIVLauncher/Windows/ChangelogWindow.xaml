<Window
    x:Class="XIVLauncher.Windows.ChangelogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mahIcon="http://metro.mahapps.com/winfx/xaml/iconpacks"
    mc:Ignorable="d"
    Title="更新日志"
    Width="600"
    WindowStartupLocation="CenterScreen"
    Icon="pack://application:,,,/Resources/dalamud_icon.ico"
    ResizeMode="NoResize"
    SizeToContent="Height"
    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
    Background="{DynamicResource MaterialDesign.Brush.Background}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="14"
    Topmost="True">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Xaml/Components/WindowAnimations.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowLoadAnimation}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="WindowAnimationLayer" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="WindowAnimationLayerTransform" Y="20" />
        </Grid.RenderTransform>
        
        <Border Padding="24">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <materialDesign:PackIcon Kind="Globe" Width="32" Height="32" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <TextBlock Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Text="更新日志" VerticalAlignment="Center" FontWeight="SemiBold" />
                </StackPanel>
                
                <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto" Margin="0,0,0,24" Padding="0,0,16,0">
                    <StackPanel>
                        <TextBlock x:Name="UpdateNotice" TextWrapping="Wrap" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Text="{Binding UpdateNotice}" Margin="0,0,0,16" />
                        <TextBlock x:Name="ChangeLogText" TextWrapping="Wrap" Text="{Binding ChangeLogText}" />
                    </StackPanel>
                </ScrollViewer>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedButton}" x:Name="DiscordButton">
                        <StackPanel Orientation="Horizontal">
                            <mahIcon:PackIconSimpleIcons Kind="Discord" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Discord" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Click="CloseButton_Click" Content="确定" Width="100" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
