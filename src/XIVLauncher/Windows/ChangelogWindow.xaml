<Window
    x:Class="XIVLauncher.Windows.ChangelogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mahIcon="http://metro.mahapps.com/winfx/xaml/iconpacks"
    mc:Ignorable="d"
    Title="更新日志"
    Height="Auto"
    MaxWidth="800"
    WindowStartupLocation="CenterScreen"
    Icon="pack://application:,,,/Resources/dalamud_icon.ico"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
    Background="{DynamicResource MaterialDesign.Brush.Background}"
    Topmost="True">
    <StackPanel>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="UpdateNotice"
                               Margin="10,10,10,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                               Text="{Binding UpdateNotice}" />
                    <TextBlock x:Name="ChangeLogText"
                               Margin="10"
                               MaxWidth="650"
                               Height="Auto"
                               TextWrapping="Wrap"
                               Text="{Binding ChangeLogText}" />
                </StackPanel>

                <materialDesign:PackIcon Kind="Globe"
                                         HorizontalAlignment="Stretch"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                         VerticalAlignment="Stretch"
                                         Width="30"
                                         Height="30"
                                         Margin="10,0,20,0" />
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0 15 10 10">
            <Button Style="{DynamicResource MaterialDesignFlatButton}"
                    HorizontalAlignment="Left"
                    x:Name="DiscordButton"
                    Margin="0,0,5,0">
                <StackPanel Orientation="Horizontal">
                    <mahIcon:PackIconSimpleIcons Kind="Discord" />
                    <TextBlock Margin="8 0 0 0"
                               VerticalAlignment="Center"
                               Text="Discord" />
                </StackPanel>
            </Button>

            <Button Margin="0,0,0,0"
                    HorizontalAlignment="Right"
                    Click="CloseButton_Click"
                    Content="确定" />
        </StackPanel>
    </StackPanel>
</Window>
