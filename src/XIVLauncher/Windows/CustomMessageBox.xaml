<Window
    x:Class="XIVLauncher.Windows.CustomMessageBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mahIcon="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="XIVLauncher Error"
    MinWidth="600"
    MaxWidth="850"
    MinHeight="250"
    Background="Transparent"
    Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
    Icon="pack://application:,,,/Resources/dalamud_icon.ico"
    WindowStyle="None"
    AllowsTransparency="True"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="14"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <Storyboard x:Key="WindowLoadAnimation">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                             Storyboard.TargetProperty="Y"
                             From="30" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="WindowCloseAnimation">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                             Storyboard.TargetProperty="Y"
                             From="0" To="30" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowLoadAnimation}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="16">
        <materialDesign:Card x:Name="RootBorder"
                             Background="{DynamicResource MaterialDesign.Brush.Background}"
                             UniformCornerRadius="16"
                             Opacity="0"
                             materialDesign:ElevationAssist.Elevation="Dp8">
            <materialDesign:Card.RenderTransform>
                <TranslateTransform x:Name="TranslateTransform" Y="30" />
            </materialDesign:Card.RenderTransform>

            <Grid MouseMove="CustomMessageBox_MouseMove" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ContextMenu>
                    <ContextMenu Style="{StaticResource MaterialDesignContextMenu}">
                        <ContextMenu.Resources>
                            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource MaterialDesignMenuItem}" />
                        </ContextMenu.Resources>
                        <MenuItem Header="复制 (_C)" Command="{Binding Path=CopyMessageTextCommand}">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="ContentCopy" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Grid.ContextMenu>

                <!-- Header / Title Area -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon x:Name="ErrorPackIcon"
                                             Kind="AlertOctagon"
                                             Width="32"
                                             Height="32"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Error}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,16,0" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- Custom Title (previously on the window title bar) -->
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                   Margin="0,0,0,12"
                                   TextWrapping="Wrap" />

                        <TextBlock x:Name="MessageTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="24"
                                   Opacity="0.85"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">
                            <!-- Content injected via code-behind -->
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Details / Description Area (Stack Trace, Log) -->
                <RichTextBox x:Name="DescriptionTextBox"
                             Grid.Row="1"
                             Margin="0,24,0,0"
                             Padding="16"
                             AcceptsReturn="True"
                             IsDocumentEnabled="True"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             SpellCheck.IsEnabled="False"
                             materialDesign:HintAssist.Hint="详细错误日志与环境信息"
                             MaxHeight="250"
                             MinHeight="120"
                             FontSize="13"
                             FontFamily="Consolas, Courier New, monospace"
                             Background="{DynamicResource MaterialDesign.Brush.Surface}"
                             Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}">
                    <RichTextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="8" />
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>

                <!-- Input TextBox -->
                <TextBox x:Name="InputTextBox"
                         Grid.Row="2"
                         Margin="0,24,0,0"
                         Padding="16,14"
                         VerticalAlignment="Center"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="在此处输入内容"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         materialDesign:TextFieldAssist.UnderlineBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                         Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />

                <!-- Actions Area -->
                <Grid Grid.Row="3" Margin="0,36,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Secondary Tools -->
                    <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Button x:Name="OfficialLauncherButton" Style="{DynamicResource MaterialDesignFlatButton}"
                                Margin="0,0,8,8" Click="OfficialLauncherButton_Click" ToolTip="启动官方启动器"
                                Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Launch" VerticalAlignment="Center" Width="18"
                                                         Height="18" />
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="官方启动器"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DiscordButton" Style="{DynamicResource MaterialDesignFlatButton}"
                                Margin="0,0,8,8" Click="DiscordButton_Click" ToolTip="打开 Discord 获取帮助"
                                Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                            <StackPanel Orientation="Horizontal">
                                <mahIcon:PackIconSimpleIcons Kind="Discord" VerticalAlignment="Center" Width="18"
                                                             Height="18" />
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Discord"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NewGitHubIssueButton" Style="{DynamicResource MaterialDesignFlatButton}"
                                Margin="0,0,8,8" Click="NewGitHubIssueButton_OnClick" ToolTip="在 GitHub 上报告问题"
                                Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Github" VerticalAlignment="Center" Width="18"
                                                         Height="18" />
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="GitHub"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="IntegrityReportButton" Style="{DynamicResource MaterialDesignFlatButton}"
                                Margin="0,0,8,8" Click="IntegrityReportButton_Click" ToolTip="查看文件完整性报告"
                                Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocument" VerticalAlignment="Center" Width="18"
                                                         Height="18" />
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="完整性报告"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="PackTroubleshooting" Style="{DynamicResource MaterialDesignFlatButton}"
                                Margin="0,0,8,8" Click="PackTroubleshooting_OnClick"
                                Visibility="{Binding PackTroubleshootingVisibility}" ToolTip="生成用于排查问题的打包日志"
                                Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Bug" VerticalAlignment="Center" Width="18" Height="18" />
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="打包日志"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- Right: Primary Actions -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Bottom" Margin="0,0,0,8">
                        <Button x:Name="Button3" Margin="12,0,0,0" MinWidth="100" Click="Button3_Click"
                                Content="Button3" Style="{DynamicResource MaterialDesignOutlinedButton}" />
                        <Button x:Name="Button2" Margin="12,0,0,0" MinWidth="100" Click="Button2_Click"
                                Content="Button2" Style="{DynamicResource MaterialDesignOutlinedButton}" />
                        <Button x:Name="Button1" Margin="12,0,0,0" MinWidth="100" Click="Button1_Click"
                                Content="Button1" Style="{DynamicResource MaterialDesignRaisedButton}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>
