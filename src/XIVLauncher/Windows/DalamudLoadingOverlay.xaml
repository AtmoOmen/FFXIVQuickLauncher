<Window x:Class="XIVLauncher.Windows.DalamudLoadingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
        mc:Ignorable="d"
        Title="XIVLauncher Update" WindowStartupLocation="Manual" Left="0" Top="0"
        Icon="pack://application:,,,/Resources/dalamud_icon.ico" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None" Height="186.088" Width="270"
        Loaded="DalamudLoadingOverlay_OnLoaded" d:DataContext="{d:DesignInstance viewModel:DalamudLoadingOverlayViewModel}">
    <Grid Margin="0,0,0,0">
        <materialDesign:Card Background="{DynamicResource MaterialDesign.Brush.Background}" Height="124" Margin="0,0,56,0">
            <StackPanel Margin="16,16,16,0">
                <TextBlock Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" HorizontalAlignment="Center"
                           Text="{Binding UpdateText}" />

                <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Value="{Binding ProgressValue}"
                             Visibility="{Binding IsProgressBarVisible}"
                             Margin="0,20,0,0" />

                <TextBlock Foreground="DarkGray" Margin="0, 16,0,0" TextAlignment="Center"
                           Text="{Binding ProgressText}" />
                <TextBlock Foreground="DarkGray" Margin="0, 4,0,0" TextAlignment="Center"
                           Text="{Binding PercentageText}" />
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
