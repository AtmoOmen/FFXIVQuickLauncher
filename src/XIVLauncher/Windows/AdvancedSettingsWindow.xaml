<Window x:Class="XIVLauncher.Windows.AdvancedSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
        mc:Ignorable="d"
        Title="高级设置" SizeToContent="Height" Width="450"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/dalamud_icon.ico" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Medium"
        d:DataContext="{d:DesignInstance viewModel:AdvancedSettingsViewModel}">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="10,20,0,50">
            <CheckBox x:Name="ExitLauncherAfterGameExitCheckbox"
                      Content="等待游戏退出后再关闭 XIVLauncher"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,7"
                      Foreground="DarkGray"
                      IsChecked="{Binding ExitLauncherAfterGameExit}" />
            <CheckBox x:Name="TreatNonZeroExitCodeAsFailureCheckbox"
                      Content="将非零退出码视为崩溃"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,7"
                      Foreground="DarkGray"
                      ToolTip="开启后，发生异常退出时会自动重新打开 XIVLauncher 界面"
                      IsChecked="{Binding TreatNonZeroExitCodeAsFailure}"
                      IsEnabled="{Binding ElementName=ExitLauncherAfterGameExitCheckbox, Path=IsChecked}" />
            <CheckBox x:Name="EnableVerboseLog"
                      Content="将日志级别提升为 Verbose"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,7"
                      Foreground="DarkGray"
                      ToolTip="开启后会输出更详细的日志，日志文件体积也会明显变大"
                      IsChecked="{Binding EnableVerboseLog}" />
            <CheckBox x:Name="EnableSkipUpdate"
                      Content="跳过 XIVLauncher 更新"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,7"
                      Foreground="DarkGray"
                      IsChecked="{Binding EnableSkipUpdate}" />
        </StackPanel>

        <Button Content="确认"
                Width="79"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="0,0,10,10"
                Click="CloseButton_OnClick" />
    </Grid>
</Window>
