<Window x:Class="XIVLauncher.Windows.GenericAddonSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:XIVLauncher.Xaml.Components"
        xmlns:viewModel="clr-namespace:XIVLauncher.Windows.ViewModel"
        mc:Ignorable="d"
        Title="配置自动启动项" Width="533.495"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/dalamud_icon.ico" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Bold"
        d:DataContext="{d:DesignInstance viewModel:GenericAddonSetupWindowViewModel}">
    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Vertical">
            <TextBlock Text="文件路径"
                       Margin="0,0,0,4" />
            <components:FileEntry x:Name="PathEntry"
                                  Description="Select an Addon file"
                                  Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                  Filters="EXE File, *.exe;Powershell Script, *.ps1;Shell Script, *.bat"
                                  Width="400"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,12" />
            <TextBlock Text="命令行参数"
                       Width="400"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,4" />
            <TextBox x:Name="CommandLineTextBox"
                     Width="400"
                     Text="{Binding CommandLine, UpdateSourceTrigger=PropertyChanged}"
                     HorizontalAlignment="Left"
                     Margin="0,0,0,12" />
            <CheckBox x:Name="AdminCheckBox"
                      Content="以管理员身份运行"
                      Width="400"
                      HorizontalAlignment="Left"
                      IsChecked="{Binding RunAsAdmin}"
                      Margin="0,0,0,8" />
            <CheckBox x:Name="RunOnCloseCheckBox"
                      Content="游戏结束时再运行"
                      Width="400"
                      HorizontalAlignment="Left"
                      IsChecked="{Binding RunOnClose}"
                      Margin="0,0,0,8" />
            <CheckBox x:Name="KillCheckBox"
                      Content="游戏结束时停止运行"
                      Width="400"
                      HorizontalAlignment="Left"
                      IsEnabled="{Binding CanKillAfterClose}"
                      IsChecked="{Binding KillAfterClose}" />
        </StackPanel>

        <Button Grid.Row="1"
                Content="确定"
                Width="79"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Click="NextButton_Click" />
    </Grid>
</Window>
